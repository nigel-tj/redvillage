<div class="dash">
  <% if defined?(impersonating?) && impersonating? %>
    <div class="alert alert-warning alert-dismissible fade show">
      <strong>Impersonating:</strong>
      <%= current_user.name %>
      (<%= current_user.role %>)
      <%= button_to "Stop Impersonating", stop_impersonating_path, method: :delete, class: "btn btn-sm btn-outline-danger ms-2" %>
      <button class="btn-close" type="button" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <%= render "dashboards/header",
        title: "Admin Dashboard",
        eyebrow: "Command center",
        subtitle: "Welcome to the Red Cup Village admin panel. Monitor users, content, ads, and marketplace activity.",
        primary_path: users_path,
        primary_label: "Manage Users",
        primary_icon: "fas fa-users",
        user: current_user %>

  <div class="dash-stats dash-stats--auto">
    <%= render "dashboards/stat_card", label: "Total Users", value: @stats[:total_users], icon: "fas fa-users" %>
    <%= render "dashboards/stat_card", label: "DJs", value: @stats[:djs], icon: "fas fa-compact-disc" %>
    <%= render "dashboards/stat_card", label: "Artists", value: @stats[:artists], icon: "fas fa-microphone" %>
    <%= render "dashboards/stat_card", label: "Photographers", value: @stats[:photographers], icon: "fas fa-camera" %>
    <%= render "dashboards/stat_card", label: "Videographers", value: @stats[:videographers], icon: "fas fa-video" %>
    <%= render "dashboards/stat_card", label: "Members", value: @stats[:members], icon: "fas fa-user" %>
  </div>

  <div class="dash-stats dash-stats--auto">
    <%= render "dashboards/stat_card", label: "Curators", value: @stats[:curators], icon: "fas fa-bookmark" %>
    <%= render "dashboards/stat_card", label: "Designers", value: @stats[:designers], icon: "fas fa-palette" %>
    <%= render "dashboards/stat_card", label: "Editors", value: @stats[:editors], icon: "fas fa-pen" %>
    <%= render "dashboards/stat_card", label: "Creators", value: @stats[:djs] + @stats[:artists] + @stats[:photographers] + @stats[:videographers] + @stats[:curators] + @stats[:designers] + @stats[:editors], icon: "fas fa-star" %>
  </div>

  <div class="dash-stats">
    <%= render "dashboards/stat_card", label: "Galleries", value: @stats[:galleries_count], icon: "fas fa-images" %>
    <%= render "dashboards/stat_card", label: "News", value: @stats[:features_count], icon: "fas fa-newspaper" %>
    <%= render "dashboards/stat_card", label: "Videos", value: @stats[:videos_count], icon: "fas fa-film" %>
    <%= render "dashboards/stat_card", label: "Tracks", value: @stats[:tracks_count], icon: "fas fa-music" %>
  </div>

  <div class="dash-stats dash-stats--auto">
    <%= render "dashboards/stat_card", label: "Albums", value: @stats[:albums_count], icon: "fas fa-layer-group" %>
    <%= render "dashboards/stat_card", label: "Artists Profiles", value: @stats[:artists_count], icon: "fas fa-id-badge" %>
    <%= render "dashboards/stat_card", label: "Lifestyle", value: @stats[:lifestyles_count], icon: "fas fa-heart" %>
    <%= render "dashboards/stat_card", label: "Events", value: @stats[:events_count], icon: "fas fa-calendar" %>
    <%= render "dashboards/stat_card", label: "Banners", value: @stats[:banners_count], icon: "fas fa-image" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Advertising Revenue",
        action: link_to("Full Analytics", ad_revenue_dashboard_path, class: "btn-dash"),
        padded: true
      } do %>
    <div class="dash-stats mb-0">
      <%= render "dashboards/stat_card", label: "Potential Revenue", value: "$#{sprintf('%.2f', @ad_stats[:potential_revenue])}", icon: "fas fa-dollar-sign" %>
      <%= render "dashboards/stat_card", label: "Active Ads", value: @ad_stats[:active_ads], icon: "fas fa-ad" %>
      <%= render "dashboards/stat_card", label: "Impressions", value: number_with_delimiter(@ad_stats[:total_impressions]), icon: "fas fa-eye" %>
      <%= render "dashboards/stat_card", label: "Clicks", value: number_with_delimiter(@ad_stats[:total_clicks]), icon: "fas fa-mouse-pointer" %>
    </div>
  <% end %>

  <%= render layout: "dashboards/panel", locals: {
        title: "Ticket Marketplace",
        action: link_to("View Marketplace", ticket_listings_path, class: "btn-dash"),
        padded: true
      } do %>
    <div class="dash-stats mb-0">
      <%= render "dashboards/stat_card", label: "Total Listings", value: @stats[:ticket_listings_count], icon: "fas fa-ticket-alt" %>
      <%= render "dashboards/stat_card", label: "Available", value: @stats[:available_tickets_count], icon: "fas fa-check" %>
      <%= render "dashboards/stat_card", label: "Sold", value: @stats[:sold_tickets_count], icon: "fas fa-shopping-bag" %>
      <%= render "dashboards/stat_card", label: "Revenue", value: "$#{sprintf('%.2f', @stats[:total_revenue])}", icon: "fas fa-coins" %>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-4">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Users", padded: true } do %>
        <% if @stats[:recent_users].any? %>
          <ul class="dash-feed">
            <% @stats[:recent_users].each do |user| %>
              <li>
                <div>
                  <%= link_to user.name, user_path(user) %>
                  <span class="dash-badge ms-1"><%= user.role.titleize %></span>
                  <small class="text-muted d-block"><%= time_ago_in_words(user.created_at) %> ago</small>
                  <% if user_signed_in? && current_user.admin? && user != current_user %>
                    <%= button_to "Impersonate", impersonate_path(user), method: :post, class: "btn-dash-outline btn-sm mt-1" %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No users yet.</p>
        <% end %>
      <% end %>
    </div>
    <div class="col-md-4">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Galleries", padded: true } do %>
        <% if @recent_galleries.any? %>
          <ul class="dash-feed">
            <% @recent_galleries.each do |gallery| %>
              <li>
                <%= link_to gallery.name, gallery_path(gallery) %>
                <small class="text-muted"><%= time_ago_in_words(gallery.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No galleries yet.</p>
        <% end %>
      <% end %>
    </div>
    <div class="col-md-4">
      <%= render layout: "dashboards/panel", locals: { title: "Recent News", padded: true } do %>
        <% if @recent_features.any? %>
          <ul class="dash-feed">
            <% @recent_features.each do |feature| %>
              <li>
                <%= link_to feature.heading, feature_path(feature) %>
                <small class="text-muted"><%= time_ago_in_words(feature.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No news articles yet.</p>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="row g-3 mt-1">
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Tracks", padded: true } do %>
        <% if @recent_tracks.any? %>
          <ul class="dash-feed">
            <% @recent_tracks.each do |track| %>
              <li>
                <%= link_to track.title, track_path(track) %>
                <small class="text-muted"><%= time_ago_in_words(track.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No tracks yet.</p>
        <% end %>
      <% end %>
    </div>
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Events", padded: true } do %>
        <% if @recent_events.any? %>
          <ul class="dash-feed">
            <% @recent_events.each do |event| %>
              <li>
                <div>
                  <%= link_to event.name, event_path(event) %>
                  <small class="text-muted d-block">
                    <%= event.date.strftime("%B %d, %Y") if event.date %>
                  </small>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No events yet.</p>
        <% end %>
      <% end %>
    </div>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Recent Ticket Listings",
        action: safe_join([
          link_to("View All", ticket_listings_path, class: "btn-dash-outline me-1"),
          link_to("Create Listing", new_ticket_listing_path, class: "btn-dash")
        ])
      } do %>
    <% if @recent_ticket_listings.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Event</th>
              <th>Seller</th>
              <th>Type</th>
              <th>Price</th>
              <th>Qty</th>
              <th>Status</th>
              <th>Created</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @recent_ticket_listings.each do |listing| %>
              <tr>
                <td>
                  <strong><%= listing.event.name %></strong>
                  <% if listing.event.date %>
                    <br><small class="text-muted"><%= listing.event.date.strftime("%b %d, %Y") %></small>
                  <% end %>
                </td>
                <td><%= link_to listing.user.name, user_path(listing.user) %></td>
                <td>
                  <% if listing.ticket_type == 'vip' %>
                    <span class="dash-badge">VIP</span>
                  <% else %>
                    <span class="dash-badge">Standard</span>
                  <% end %>
                </td>
                <td><strong><%= listing.formatted_price %></strong></td>
                <td><%= listing.available_quantity %>/<%= listing.quantity %></td>
                <td>
                  <% if listing.status == 'available' %>
                    <span class="badge bg-success">Available</span>
                  <% elsif listing.status == 'sold' %>
                    <span class="badge bg-danger">Sold</span>
                  <% elsif listing.status == 'pending' %>
                    <span class="badge bg-warning text-dark">Pending</span>
                  <% else %>
                    <span class="badge bg-secondary"><%= listing.status.titleize %></span>
                  <% end %>
                </td>
                <td><small class="text-muted"><%= time_ago_in_words(listing.created_at) %> ago</small></td>
                <td><%= link_to "View", ticket_listing_path(listing), class: "btn-dash btn-sm" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No ticket listings yet.</p>
        <%= link_to "Create First Listing", new_ticket_listing_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
