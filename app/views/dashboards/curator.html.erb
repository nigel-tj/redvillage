<div class="dash">
  <%= render "dashboards/header",
        title: "Curator Dashboard",
        eyebrow: "Editorial desk",
        subtitle: "Welcome back, #{@user.name}. Curate and manage content across the platform.",
        primary_path: new_feature_upload_path,
        primary_label: "Create Article",
        user: @user %>

  <div class="dash-stats">
    <%= render "dashboards/stat_card", label: "News Articles", value: @stats[:total_features], icon: "fas fa-newspaper" %>
    <%= render "dashboards/stat_card", label: "Galleries", value: @stats[:total_galleries], icon: "fas fa-images" %>
    <%= render "dashboards/stat_card", label: "Videos", value: @stats[:total_videos], icon: "fas fa-video" %>
    <%= render "dashboards/stat_card", label: "My Articles", value: @stats[:my_features], icon: "fas fa-pen" %>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: {
            title: "News Articles",
            action: link_to("Create Article", new_feature_upload_path, class: "btn-dash")
          } do %>
        <% if @features.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Heading</th>
                  <th>Created</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @features.first(10).each do |feature| %>
                  <tr>
                    <td><strong><%= feature.heading || "Untitled" %></strong></td>
                    <td><%= time_ago_in_words(feature.created_at) %> ago</td>
                    <td><%= link_to "View", feature_path(feature), class: "btn-dash btn-sm" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="dash-empty padded">
            <p>No articles yet.</p>
            <%= link_to "Create Your First Article", new_feature_upload_path, class: "btn-dash" %>
          </div>
        <% end %>
      <% end %>
    </div>
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Content", padded: true } do %>
        <h6 class="text-muted text-uppercase small fw-bold mb-2">Galleries</h6>
        <% if @galleries.any? %>
          <ul class="dash-feed mb-3">
            <% @galleries.each do |gallery| %>
              <li>
                <%= link_to gallery.name, gallery_path(gallery) %>
                <small class="text-muted"><%= time_ago_in_words(gallery.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small">No galleries yet.</p>
        <% end %>

        <h6 class="text-muted text-uppercase small fw-bold mb-2 mt-3">Videos</h6>
        <% if @videos.any? %>
          <ul class="dash-feed">
            <% @videos.each do |video| %>
              <li>
                <%= link_to video.link&.truncate(40) || "Video #{video.id}", video_path(video) %>
                <small class="text-muted"><%= time_ago_in_words(video.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small mb-0">No videos yet.</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
