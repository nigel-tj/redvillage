<div class="dash">
  <%= render "dashboards/header",
        title: "Artist Dashboard",
        eyebrow: "Creator studio",
        subtitle: "Welcome back, #{@user.name}. Manage your music, tracks, and albums.",
        primary_path: new_track_path,
        primary_label: "Upload New Track",
        user: @user %>

  <div class="dash-stats">
    <%= render "dashboards/stat_card", label: "Total Tracks", value: @stats[:total_tracks], icon: "fas fa-music" %>
    <%= render "dashboards/stat_card", label: "My Tracks", value: @stats[:my_tracks], icon: "fas fa-headphones" %>
    <%= render "dashboards/stat_card", label: "Total Albums", value: @stats[:total_albums], icon: "fas fa-compact-disc" %>
    <%= render "dashboards/stat_card", label: "My Albums", value: @stats[:my_albums], icon: "fas fa-layer-group" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "My Tracks",
        action: link_to("Upload New Track", new_track_path, class: "btn-dash")
      } do %>
    <% if @user_tracks.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Track Title</th>
              <th>Album</th>
              <th>Category</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @user_tracks.each do |track| %>
              <tr>
                <td><strong><%= track.title %></strong></td>
                <td><%= track.album&.name || "—" %></td>
                <td>
                  <% if track.category.present? %>
                    <span class="dash-badge"><%= humanize_category(track.category) %></span>
                  <% end %>
                </td>
                <td><%= time_ago_in_words(track.created_at) %> ago</td>
                <td>
                  <%= link_to "View", track_path(track), class: "btn-dash btn-sm me-1" %>
                  <%= link_to "Edit", edit_track_path(track), class: "btn-dash-outline btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No tracks uploaded yet.</p>
        <%= link_to "Upload Your First Track", new_track_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: {
        title: "My Albums",
        action: link_to("Create New Album", new_album_path, class: "btn-dash")
      } do %>
    <% if @user_albums.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Album Name</th>
              <th>Artist</th>
              <th>Tracks</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @user_albums.each do |album| %>
              <tr>
                <td><strong><%= album.name %></strong></td>
                <td><%= album.artist_name || "—" %></td>
                <td><%= Track.where(album_id: album.id).count %></td>
                <td><%= time_ago_in_words(album.created_at) %> ago</td>
                <td>
                  <%= link_to "View", album_path(album), class: "btn-dash btn-sm me-1" %>
                  <%= link_to "Edit", edit_album_path(album), class: "btn-dash-outline btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No albums created yet.</p>
        <%= link_to "Create Your First Album", new_album_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: { title: "Quick Actions", padded: true } do %>
    <div class="dash-actions">
      <%= link_to new_track_path, class: "dash-action" do %>
        <i class="fas fa-upload"></i><span>Upload Track</span>
      <% end %>
      <%= link_to new_album_path, class: "dash-action" do %>
        <i class="fas fa-plus"></i><span>Create Album</span>
      <% end %>
      <%= link_to tracks_path, class: "dash-action" do %>
        <i class="fas fa-list"></i><span>All Tracks</span>
      <% end %>
      <%= link_to albums_path, class: "dash-action" do %>
        <i class="fas fa-compact-disc"></i><span>All Albums</span>
      <% end %>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Tracks", padded: true } do %>
        <% if @tracks.any? %>
          <ul class="dash-feed">
            <% @tracks.first(5).each do |track| %>
              <li>
                <div>
                  <%= link_to track.title, track_path(track) %>
                  <small class="text-muted d-block"><%= track.artist_name || "Unknown Artist" %></small>
                </div>
                <small class="text-muted text-nowrap"><%= time_ago_in_words(track.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No tracks available.</p>
        <% end %>
      <% end %>
    </div>
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Albums", padded: true } do %>
        <% if @albums.any? %>
          <ul class="dash-feed">
            <% @albums.first(5).each do |album| %>
              <li>
                <div>
                  <%= link_to album.name, album_path(album) %>
                  <small class="text-muted d-block"><%= album.artist_name || "Unknown Artist" %></small>
                </div>
                <small class="text-muted text-nowrap"><%= time_ago_in_words(album.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No albums available.</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
