<div class="dash">
  <%= render "dashboards/header",
        title: "Videographer Dashboard",
        eyebrow: "Motion desk",
        subtitle: "Welcome back, #{@user.name}. Manage your video content.",
        primary_path: new_video_upload_path,
        primary_label: "Upload Video",
        user: @user %>

  <div class="dash-stats">
    <%= render "dashboards/stat_card", label: "Total Videos", value: @stats[:total_videos], icon: "fas fa-video" %>
    <%= render "dashboards/stat_card", label: "My Videos", value: @stats[:my_videos], icon: "fas fa-film" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "My Videos",
        action: link_to("Upload New Video", new_video_upload_path, class: "btn-dash")
      } do %>
    <% if @videos.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Video</th>
              <th>Category</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @videos.each do |video| %>
              <tr>
                <td>
                  <% if video.link.present? %>
                    <%= link_to video.link.truncate(50), video.link, target: "_blank", rel: "noopener" %>
                  <% else %>
                    <span class="text-muted">No link</span>
                  <% end %>
                </td>
                <td>
                  <% if video.category.present? %>
                    <span class="dash-badge"><%= humanize_category(video.category) %></span>
                  <% end %>
                </td>
                <td><%= time_ago_in_words(video.created_at) %> ago</td>
                <td>
                  <%= link_to "View", video_path(video), class: "btn-dash btn-sm me-1" %>
                  <%= link_to "Edit", edit_video_path(video), class: "btn-dash-outline btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No videos uploaded yet.</p>
        <%= link_to "Upload Your First Video", new_video_upload_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: { title: "Recent Videos", padded: true } do %>
    <% if @recent_videos.any? %>
      <ul class="dash-feed">
        <% @recent_videos.each do |video| %>
          <li>
            <%= link_to video.link&.truncate(60) || "Video #{video.id}", video_path(video) %>
            <small class="text-muted"><%= time_ago_in_words(video.created_at) %> ago</small>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No videos available.</p>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: { title: "Quick Actions", padded: true } do %>
    <div class="dash-actions">
      <%= link_to new_video_upload_path, class: "dash-action" do %>
        <i class="fas fa-upload"></i><span>Upload Video</span>
      <% end %>
      <%= link_to all_videos_path, class: "dash-action" do %>
        <i class="fas fa-list"></i><span>All Videos</span>
      <% end %>
      <%= link_to videos_path, class: "dash-action" do %>
        <i class="fas fa-globe"></i><span>Public Videos</span>
      <% end %>
    </div>
  <% end %>
</div>
