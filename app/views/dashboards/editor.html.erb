<div class="dash">
  <%= render "dashboards/header",
        title: "Editor Dashboard",
        eyebrow: "Review queue",
        subtitle: "Welcome back, #{@user.name}. Review and manage content across all categories.",
        primary_path: new_feature_upload_path,
        primary_label: "New Article",
        user: @user %>

  <div class="dash-stats dash-stats--auto">
    <%= render "dashboards/stat_card", label: "News", value: @stats[:total_features], icon: "fas fa-newspaper" %>
    <%= render "dashboards/stat_card", label: "Galleries", value: @stats[:total_galleries], icon: "fas fa-images" %>
    <%= render "dashboards/stat_card", label: "Videos", value: @stats[:total_videos], icon: "fas fa-video" %>
    <%= render "dashboards/stat_card", label: "Tracks", value: @stats[:total_tracks], icon: "fas fa-music" %>
    <%= render "dashboards/stat_card", label: "Pending Review", value: @stats[:pending_review], icon: "fas fa-clock" %>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: {
            title: "Recent News Articles",
            action: link_to("View All", "/admin_index", class: "btn-dash-outline")
          } do %>
        <% if @features.any? %>
          <ul class="dash-feed" style="padding: 1rem 1.25rem;">
            <% @recent_features.each do |feature| %>
              <li>
                <div>
                  <%= link_to feature.heading || "Untitled", feature_path(feature) %>
                  <small class="text-muted d-block"><%= time_ago_in_words(feature.created_at) %> ago</small>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="dash-empty padded"><p>No articles yet.</p></div>
        <% end %>
      <% end %>
    </div>
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Content Overview", padded: true } do %>
        <h6 class="text-muted text-uppercase small fw-bold mb-2">Galleries</h6>
        <% if @galleries.any? %>
          <ul class="dash-feed mb-3">
            <% @galleries.each do |gallery| %>
              <li>
                <%= link_to gallery.name, gallery_path(gallery) %>
                <small class="text-muted"><%= time_ago_in_words(gallery.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small">No galleries yet.</p>
        <% end %>

        <h6 class="text-muted text-uppercase small fw-bold mb-2 mt-3">Videos</h6>
        <% if @videos.any? %>
          <ul class="dash-feed mb-3">
            <% @videos.each do |video| %>
              <li>
                <%= link_to video.link&.truncate(40) || "Video #{video.id}", video_path(video) %>
                <small class="text-muted"><%= time_ago_in_words(video.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small">No videos yet.</p>
        <% end %>

        <h6 class="text-muted text-uppercase small fw-bold mb-2 mt-3">Tracks</h6>
        <% if @tracks.any? %>
          <ul class="dash-feed">
            <% @tracks.each do |track| %>
              <li>
                <%= link_to track.title, track_path(track) %>
                <small class="text-muted"><%= time_ago_in_words(track.created_at) %> ago</small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted small mb-0">No tracks yet.</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
