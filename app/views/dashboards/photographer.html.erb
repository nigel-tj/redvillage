<div class="dash">
  <%= render "dashboards/header",
        title: "Photographer Dashboard",
        eyebrow: "Visual archive",
        subtitle: "Welcome back, #{@user.name}. Manage your galleries and images.",
        primary_path: new_gallery_path,
        primary_label: "Create Gallery",
        user: @user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Total Galleries", value: @stats[:total_galleries], icon: "fas fa-images" %>
    <%= render "dashboards/stat_card", label: "My Galleries", value: @stats[:my_galleries], icon: "fas fa-folder-open" %>
    <%= render "dashboards/stat_card", label: "Total Images", value: @stats[:total_images], icon: "fas fa-camera" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "My Galleries",
        action: link_to("Create New Gallery", new_gallery_path, class: "btn-dash")
      } do %>
    <% if @galleries.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Gallery Name</th>
              <th>Category</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @galleries.each do |gallery| %>
              <tr>
                <td><strong><%= gallery.name %></strong></td>
                <td>
                  <% if gallery.category.present? %>
                    <span class="dash-badge"><%= humanize_category(gallery.category) %></span>
                  <% end %>
                </td>
                <td><%= time_ago_in_words(gallery.created_at) %> ago</td>
                <td>
                  <%= link_to "View", gallery_path(gallery), class: "btn-dash btn-sm me-1" %>
                  <%= link_to "Edit", edit_gallery_path(gallery), class: "btn-dash-outline btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No galleries created yet.</p>
        <%= link_to "Create Your First Gallery", new_gallery_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: { title: "Recent Galleries", padded: true } do %>
    <% if @recent_galleries.any? %>
      <ul class="dash-feed">
        <% @recent_galleries.each do |gallery| %>
          <li>
            <%= link_to gallery.name, gallery_path(gallery) %>
            <small class="text-muted"><%= time_ago_in_words(gallery.created_at) %> ago</small>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No galleries available.</p>
    <% end %>
  <% end %>
</div>
