<div class="dash">
  <%= render "dashboards/header",
        title: "Member Dashboard",
        eyebrow: "Ticket marketplace",
        subtitle: "Welcome back, #{current_user.name}. Manage your listings and explore the marketplace.",
        primary_path: new_ticket_listing_path,
        primary_label: "List Your Tickets",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Available Listings", value: @available_count, icon: "fas fa-ticket-alt" %>
    <%= render "dashboards/stat_card", label: "Sold Listings", value: @sold_count, icon: "fas fa-check-circle" %>
    <%= render "dashboards/stat_card", label: "Total Revenue", value: "$#{sprintf('%.2f', @total_revenue)}", icon: "fas fa-dollar-sign" %>
  </div>

  <div class="row g-3">
    <div class="col-lg-7">
      <%= render layout: "dashboards/panel", locals: {
            title: "My Recent Listings",
            action: link_to("View All", my_tickets_path, class: "btn-dash-outline")
          } do %>
        <% if @ticket_listings.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Event</th>
                  <th>Type</th>
                  <th>Price</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @ticket_listings.each do |listing| %>
                  <tr>
                    <td>
                      <strong><%= listing.event.name %></strong>
                      <br><small class="text-muted"><%= time_ago_in_words(listing.created_at) %> ago</small>
                    </td>
                    <td>
                      <% if listing.ticket_type == 'vip' %>
                        <span class="dash-badge">VIP</span>
                      <% else %>
                        <span class="dash-badge">Standard</span>
                      <% end %>
                    </td>
                    <td><strong><%= listing.formatted_price %></strong></td>
                    <td>
                      <% if listing.status == 'available' %>
                        <span class="badge bg-success">Available</span>
                      <% elsif listing.status == 'sold' %>
                        <span class="badge bg-danger">Sold</span>
                      <% else %>
                        <span class="badge bg-secondary"><%= listing.status.titleize %></span>
                      <% end %>
                    </td>
                    <td><%= link_to "View", ticket_listing_path(listing), class: "btn-dash btn-sm" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="dash-empty padded">
            <p>You haven't created any listings yet.</p>
            <%= link_to "Create Your First Listing", new_ticket_listing_path, class: "btn-dash" %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="col-lg-5">
      <%= render layout: "dashboards/panel", locals: { title: "Ticket Marketplace", padded: true } do %>
        <% if @marketplace_tickets.any? %>
          <ul class="dash-feed">
            <% @marketplace_tickets.take(3).each do |listing| %>
              <li>
                <div>
                  <%= link_to listing.event.name, ticket_listing_path(listing) %>
                  <small class="text-muted d-block">
                    <%= listing.formatted_price %> · <%= listing.available_quantity %> left
                  </small>
                </div>
              </li>
            <% end %>
          </ul>
          <%= link_to "Browse Marketplace", ticket_listings_path, class: "btn-dash w-100 mt-2 d-inline-block text-center" %>
        <% else %>
          <p class="text-muted mb-0">No tickets available yet.</p>
        <% end %>
      <% end %>

      <%= render layout: "dashboards/panel", locals: { title: "Upcoming Events", padded: true } do %>
        <% if @upcoming_events.any? %>
          <ul class="dash-feed">
            <% @upcoming_events.each do |event| %>
              <li>
                <div>
                  <strong class="d-block"><%= event.name %></strong>
                  <small class="text-muted">
                    <% if event.date %><%= event.date.strftime("%b %d, %Y") %><% end %>
                    <% if event.venue %> · <%= event.venue %><% end %>
                  </small>
                  <div class="mt-2">
                    <%= link_to "Sell Tickets", new_event_ticket_listing_path(event), class: "btn-dash-outline btn-sm" %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
          <%= link_to "View All Events", events_path, class: "btn-dash-outline w-100 mt-2 d-inline-block text-center" %>
        <% else %>
          <p class="text-muted mb-0">No upcoming events.</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
