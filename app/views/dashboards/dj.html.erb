<div class="dash">
  <%= render "dashboards/header",
        title: "DJ Dashboard",
        eyebrow: "On the decks",
        subtitle: "Welcome back, #{@user.name}. Manage events, schedules, and browse the catalogue.",
        primary_path: events_path,
        primary_label: "View Events",
        primary_icon: "fas fa-calendar",
        user: @user %>

  <%= render layout: "dashboards/panel", locals: { title: "Upcoming Events" } do %>
    <% if @upcoming_events.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Event Name</th>
              <th>Date</th>
              <th>Venue</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @upcoming_events.each do |event| %>
              <tr>
                <td><strong><%= event.name %></strong></td>
                <td><%= event.date ? event.date.strftime("%B %d, %Y") : "TBD" %></td>
                <td><%= event.venue || "TBD" %></td>
                <td><%= link_to "View", event_path(event), class: "btn-dash btn-sm" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded"><p>No upcoming events scheduled.</p></div>
    <% end %>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Recent Events", padded: true } do %>
        <% if @events.any? %>
          <ul class="dash-feed">
            <% @events.first(5).each do |event| %>
              <li>
                <div>
                  <%= link_to event.name, event_path(event) %>
                  <small class="text-muted d-block">
                    <%= event.date ? event.date.strftime("%B %d, %Y") : "Date TBD" %>
                    <% if event.venue.present? %> · <%= event.venue %><% end %>
                  </small>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No events available.</p>
        <% end %>
      <% end %>
    </div>
    <div class="col-md-6">
      <%= render layout: "dashboards/panel", locals: { title: "Quick Actions", padded: true } do %>
        <div class="dash-actions" style="grid-template-columns: 1fr 1fr;">
          <%= link_to events_path, class: "dash-action" do %>
            <i class="fas fa-calendar"></i><span>All Events</span>
          <% end %>
          <%= link_to tracks_path, class: "dash-action" do %>
            <i class="fas fa-music"></i><span>Browse Tracks</span>
          <% end %>
          <%= link_to albums_path, class: "dash-action" do %>
            <i class="fas fa-compact-disc"></i><span>Albums</span>
          <% end %>
          <%= link_to artists_path, class: "dash-action" do %>
            <i class="fas fa-users"></i><span>Artists</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%= render layout: "dashboards/panel", locals: { title: "Available Music Tracks" } do %>
    <% if @tracks.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Track Title</th>
              <th>Artist</th>
              <th>Album</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @tracks.each do |track| %>
              <tr>
                <td><strong><%= track.title %></strong></td>
                <td><%= track.artist_name || "Unknown" %></td>
                <td><%= track.album&.name || "—" %></td>
                <td><%= link_to "View", track_path(track), class: "btn-dash btn-sm" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded"><p>No tracks available.</p></div>
    <% end %>
  <% end %>
</div>
