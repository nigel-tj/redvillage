<div class="dash">
  <%= render "dashboards/header",
        title: "Designer Dashboard",
        eyebrow: "Brand studio",
        subtitle: "Welcome back, #{@user.name}. Manage banners and visual design assets.",
        primary_path: new_banner_upload_path,
        primary_label: "Create Banner",
        user: @user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Total Banners", value: @stats[:total_banners], icon: "fas fa-image" %>
    <%= render "dashboards/stat_card", label: "My Banners", value: @stats[:my_banners], icon: "fas fa-palette" %>
    <%= render "dashboards/stat_card", label: "Active Banners", value: @stats[:active_banners], icon: "fas fa-bolt" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "My Banners",
        action: link_to("Create New Banner", new_banner_upload_path, class: "btn-dash")
      } do %>
    <% if @banners.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Banner Name</th>
              <th>Page</th>
              <th>Title</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @banners.each do |banner| %>
              <tr>
                <td><strong><%= banner.name || "Untitled Banner" %></strong></td>
                <td>
                  <% if banner.page.present? %>
                    <span class="dash-badge"><%= humanize_category(banner.page) %></span>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td><%= banner.title.presence || "—" %></td>
                <td>
                  <%= link_to "View", main_banner_path(banner), class: "btn-dash btn-sm me-1" %>
                  <%= link_to "Edit", edit_main_banner_path(banner), class: "btn-dash-outline btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No banners created yet.</p>
        <%= link_to "Create Your First Banner", new_banner_upload_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: { title: "Recent Banners", padded: true } do %>
    <% if @recent_banners.any? %>
      <ul class="dash-feed">
        <% @recent_banners.each do |banner| %>
          <li>
            <div>
              <%= link_to banner.name || "Untitled Banner", main_banner_path(banner) %>
              <small class="text-muted d-block">
                <% if banner.page.present? %>Page: <%= banner.page %><% end %>
                <% if banner.title.present? %> — <%= banner.title %><% end %>
              </small>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No banners available.</p>
    <% end %>
  <% end %>
</div>
