<div class="dash">
  <%= render "dashboards/header",
        title: "#{@store.name} Dashboard",
        eyebrow: "Marketplace",
        subtitle: "Performance, inventory, and recent orders.",
        primary_path: new_store_product_path(@store),
        primary_label: "Add Product",
        primary_icon: "fas fa-plus",
        user: current_user %>

  <div class="dash-stats">
    <%= render "dashboards/stat_card", label: "Total Revenue", value: "$#{number_with_delimiter(@stats[:total_revenue].round(2))}", icon: "fas fa-dollar-sign" %>
    <%= render "dashboards/stat_card", label: "Total Orders", value: @stats[:total_orders], icon: "fas fa-shopping-bag" %>
    <%= render "dashboards/stat_card", label: "Products", value: "#{@stats[:active_products]}/#{@stats[:total_products]}", icon: "fas fa-box" %>
    <%= render "dashboards/stat_card", label: "Avg Order", value: "$#{number_with_delimiter(@stats[:average_order_value].round(2))}", icon: "fas fa-chart-line" %>
  </div>

  <%= render layout: "dashboards/panel", locals: { title: "Revenue overview", padded: true } do %>
    <div class="row text-center g-3">
      <div class="col-6 col-md-2">
        <div class="small text-muted text-uppercase fw-bold">Today</div>
        <div class="fs-5 fw-bold">$<%= number_with_delimiter(@revenue_stats[:today].round(2)) %></div>
      </div>
      <div class="col-6 col-md-2">
        <div class="small text-muted text-uppercase fw-bold">This week</div>
        <div class="fs-5 fw-bold">$<%= number_with_delimiter(@revenue_stats[:this_week].round(2)) %></div>
      </div>
      <div class="col-6 col-md-2">
        <div class="small text-muted text-uppercase fw-bold">This month</div>
        <div class="fs-5 fw-bold">$<%= number_with_delimiter(@revenue_stats[:this_month].round(2)) %></div>
      </div>
      <div class="col-6 col-md-2">
        <div class="small text-muted text-uppercase fw-bold">Last month</div>
        <div class="fs-5 fw-bold">$<%= number_with_delimiter(@revenue_stats[:last_month].round(2)) %></div>
      </div>
      <div class="col-6 col-md-2">
        <div class="small text-muted text-uppercase fw-bold">All time</div>
        <div class="fs-5 fw-bold" style="color:#a730b2;">$<%= number_with_delimiter(@revenue_stats[:all_time].round(2)) %></div>
      </div>
      <div class="col-6 col-md-2">
        <div class="small text-muted text-uppercase fw-bold">Customers</div>
        <div class="fs-5 fw-bold"><%= @customer_stats[:total_customers] %></div>
        <div class="small text-muted"><%= @customer_stats[:repeat_customers] %> repeat</div>
      </div>
    </div>
  <% end %>

  <div class="row g-3 mb-3">
    <div class="col-lg-8">
      <%= render layout: "dashboards/panel", locals: { title: "Revenue & orders (30 days)", padded: true } do %>
        <canvas id="revenueTrendsChart" height="80"></canvas>
      <% end %>
    </div>
    <div class="col-lg-4">
      <%= render layout: "dashboards/panel", locals: { title: "Orders by status", padded: true } do %>
        <canvas id="ordersByStatusChart" height="200"></canvas>
      <% end %>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-8">
      <%= render layout: "dashboards/panel", locals: {
            title: "Top products",
            action: link_to("All products", store_products_path(@store), class: "btn-dash-outline")
          } do %>
        <% if @top_products.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Sold</th>
                  <th>Revenue</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @top_products.each do |product| %>
                  <tr>
                    <td>
                      <strong><%= product.name %></strong>
                      <% if product.featured? %>
                        <span class="dash-badge ms-1">Featured</span>
                      <% end %>
                    </td>
                    <td><%= product.total_sold || 0 %></td>
                    <td><strong>$<%= number_with_delimiter((product.total_revenue || 0).round(2)) %></strong></td>
                    <td>
                      <% if product.in_stock? %>
                        <span class="dash-badge dash-badge--ok">In stock</span>
                      <% else %>
                        <span class="dash-badge dash-badge--danger">Out of stock</span>
                      <% end %>
                    </td>
                    <td><%= link_to "View", store_product_path(@store, product), class: "btn-dash btn-sm" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="dash-empty padded">
            <p>No sales yet. Add products to start tracking performance.</p>
            <%= link_to "Add Product", new_store_product_path(@store), class: "btn-dash" %>
          </div>
        <% end %>
      <% end %>

      <%= render layout: "dashboards/panel", locals: {
            title: "Recent orders",
            action: link_to("All orders", store_orders_path(@store), class: "btn-dash-outline")
          } do %>
        <% if @recent_orders.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Customer</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @recent_orders.each do |order| %>
                  <tr>
                    <td><strong>#<%= order.id %></strong></td>
                    <td><%= order.user.name %></td>
                    <td>$<%= number_with_delimiter(order.total_amount.round(2)) %></td>
                    <td><span class="dash-badge"><%= order.status.titleize %></span></td>
                    <td><%= order.created_at.strftime("%b %d, %Y") %></td>
                    <td><%= link_to "View", store_order_path(@store, order), class: "btn-dash btn-sm" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="dash-empty padded">
            <p>Orders will appear here once customers start purchasing.</p>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="col-lg-4">
      <%= render layout: "dashboards/panel", locals: { title: "Low stock", padded: true } do %>
        <% if @low_stock_products.any? %>
          <ul class="dash-feed">
            <% @low_stock_products.each do |product| %>
              <li>
                <div>
                  <%= link_to product.name, store_product_path(@store, product) %>
                  <div class="small text-muted"><%= product.inventory_quantity %> left</div>
                </div>
                <span class="dash-badge dash-badge--danger"><%= product.inventory_quantity %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="dash-empty">
            <i class="fas fa-check-circle d-block"></i>
            <p class="mb-0">Stock levels look healthy.</p>
          </div>
        <% end %>
      <% end %>

      <%= render layout: "dashboards/panel", locals: { title: "Quick stats", padded: true } do %>
        <div class="mb-3">
          <div class="d-flex justify-content-between mb-1">
            <span>Conversion rate</span>
            <strong><%= @stats[:conversion_rate] %>%</strong>
          </div>
          <div class="progress" style="height: 8px; border-radius: 999px;">
            <div class="progress-bar" style="width: <%= [@stats[:conversion_rate], 100].min %>%; background: linear-gradient(135deg, #ff6975, #a730b2);"></div>
          </div>
        </div>
        <ul class="dash-feed">
          <li><span>Pending orders</span><strong><%= @stats[:pending_orders] %></strong></li>
          <li><span>Completed orders</span><strong><%= @stats[:completed_orders] %></strong></li>
          <li><span>Out of stock</span><strong><%= @stats[:out_of_stock] %></strong></li>
        </ul>
        <div class="d-grid gap-2 mt-3">
          <%= link_to "Manage Products", store_products_path(@store), class: "btn-dash" %>
          <%= link_to "Customize Storefront", edit_store_storefront_settings_path(@store), class: "btn-dash-outline" %>
          <%= link_to "View Store", store_path(@store), class: "btn-dash-ghost", target: "_blank" %>
        </div>
      <% end %>

      <% alerts = []
         alerts << { message: "#{@stats[:out_of_stock]} products out of stock", path: store_products_path(@store) } if @stats[:out_of_stock] > 0
         alerts << { message: "#{@stats[:low_stock]} products low on stock", path: store_products_path(@store) } if @stats[:low_stock] > 0
         alerts << { message: "#{@stats[:pending_orders]} pending orders", path: store_orders_path(@store) } if @stats[:pending_orders] > 0 %>
      <%= render layout: "dashboards/panel", locals: { title: "Alerts", padded: true } do %>
        <% if alerts.any? %>
          <ul class="dash-feed">
            <% alerts.each do |alert| %>
              <li>
                <span><%= alert[:message] %></span>
                <%= link_to "View", alert[:path], class: "btn-dash-outline btn-sm" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="dash-empty">
            <p class="mb-0">All systems operational.</p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const revenueTrendsCtx = document.getElementById('revenueTrendsChart');
  if (revenueTrendsCtx) {
    const trendsData = <%= @revenue_trends.to_json.html_safe %>;
    new Chart(revenueTrendsCtx, {
      type: 'line',
      data: {
        labels: trendsData.map(d => d.date),
        datasets: [
          {
            label: 'Revenue ($)',
            data: trendsData.map(d => d.revenue),
            borderColor: '#d34d94',
            backgroundColor: 'rgba(211, 77, 148, 0.12)',
            tension: 0.4,
            yAxisID: 'y'
          },
          {
            label: 'Orders',
            data: trendsData.map(d => d.orders),
            borderColor: '#03111e',
            backgroundColor: 'rgba(3, 17, 30, 0.08)',
            tension: 0.4,
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        interaction: { mode: 'index', intersect: false },
        scales: {
          y: { type: 'linear', display: true, position: 'left', title: { display: true, text: 'Revenue ($)' } },
          y1: { type: 'linear', display: true, position: 'right', title: { display: true, text: 'Orders' }, grid: { drawOnChartArea: false } }
        },
        plugins: { legend: { position: 'top' } }
      }
    });
  }

  const ordersByStatusCtx = document.getElementById('ordersByStatusChart');
  if (ordersByStatusCtx) {
    const statusData = <%= @order_stats_by_status.to_json.html_safe %>;
    const colors = {
      pending: '#ffc107',
      processing: '#d34d94',
      shipped: '#17a2b8',
      delivered: '#28a745',
      cancelled: '#dc3545'
    };
    new Chart(ordersByStatusCtx, {
      type: 'doughnut',
      data: {
        labels: Object.keys(statusData).map(s => s.charAt(0).toUpperCase() + s.slice(1)),
        datasets: [{
          data: Object.values(statusData),
          backgroundColor: Object.keys(statusData).map(s => colors[s] || '#9aa0ae'),
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: { legend: { position: 'bottom' } }
      }
    });
  }
</script>
