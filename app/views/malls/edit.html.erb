<div class="dash">
  <%= render "dashboards/header",
        title: "Edit Mall",
        eyebrow: "Marketplace",
        subtitle: "Update details for #{@mall.name}.",
        primary_path: mall_path(@mall),
        primary_label: "View Mall",
        primary_icon: "fas fa-eye",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Mall details", padded: true } do %>
    <%= form_for @mall, html: { class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @mall %>

      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :name, "Mall name", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", required: true %>
        </div>
        <div class="col-md-6">
          <%= f.label :contact_email, "Contact email", class: "form-label" %>
          <%= f.email_field :contact_email, class: "form-control", placeholder: "Optional" %>
        </div>
        <div class="col-md-6">
          <%= f.label :contact_phone, "Contact phone", class: "form-label" %>
          <%= f.text_field :contact_phone, class: "form-control", placeholder: "Optional" %>
        </div>
        <div class="col-md-6">
          <%= f.label :address, "Address", class: "form-label" %>
          <%= f.text_field :address, class: "form-control", placeholder: "Optional location" %>
        </div>
        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 4 %>
        </div>
        <div class="col-12">
          <div class="form-check">
            <%= f.check_box :active, class: "form-check-input" %>
            <%= f.label :active, "Active — visible in the marketplace", class: "form-check-label" %>
          </div>
        </div>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: mall_path(@mall),
            submit_label: "Update Mall" %>
    <% end %>
  <% end %>
</div>
