<% content_for :title, "#{@mall.name} — Red Village" %>

<div class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><%= link_to "Malls", malls_path %></li>
      <li class="breadcrumb-item active" aria-current="page"><%= @mall.name %></li>
    </ol>
  </nav>

  <div class="rv-hero mb-4">
    <h1 class="mb-2"><%= @mall.name %></h1>
    <% if @mall.description.present? %>
      <p class="rv-sub mb-3"><%= @mall.description %></p>
    <% end %>
    <p class="small text-muted mb-0">
      <% if @mall.address.present? %><i class="fas fa-map-marker-alt me-1"></i><%= @mall.address %><br><% end %>
      <% if @mall.contact_email.present? %><i class="fas fa-envelope me-1"></i><%= mail_to @mall.contact_email %><% end %>
    </p>
  </div>

  <div class="rv-section-head">
    <h2 class="rv-gradient-text h3">Stores in this mall</h2>
    <hr class="rv-rule">
  </div>

  <% if @stores.any? %>
    <div class="row g-4">
      <% @stores.each do |store| %>
        <div class="col-md-6 col-lg-4">
          <div class="card rv-card h-100">
            <div class="card-body">
              <h3 class="h5 card-title"><%= link_to store.name, store_path(store), class: "text-decoration-none" %></h3>
              <% if store.description.present? %>
                <p class="card-text text-muted"><%= truncate(store.description, length: 120) %></p>
              <% end %>
            </div>
            <div class="card-footer border-0 bg-transparent">
              <%= link_to "Visit store", store_path(store), class: "btn btn-outline-rv btn-rv-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted py-4 mb-0">No active stores in this mall yet.</p>
  <% end %>
</div>
