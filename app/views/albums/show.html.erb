<% cover = shrine_image_url(@album, :image, :thumbnail) || shrine_image_url(@album, :image) %>
<% tracks = @album_tracks || @album.tracks %>

<div class="dash">
  <%= render "dashboards/header",
        title: @album.name,
        eyebrow: "Album",
        subtitle: [@album.artist_name.presence, pluralize(tracks.size, "track")].compact.join(" · "),
        primary_path: new_track_path(album_id: @album.id),
        primary_label: "Add Tracks",
        primary_icon: "fas fa-upload",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Tracks", value: tracks.size, icon: "fas fa-music" %>
    <%= render "dashboards/stat_card", label: "Artist", value: @album.artist_name.presence || "—", icon: "fas fa-microphone" %>
    <%= render "dashboards/stat_card", label: "Created", value: @album.created_at.strftime("%b %Y"), icon: "fas fa-calendar" %>
  </div>

  <%= render layout: "dashboards/panel", locals: { title: "Album details", padded: true } do %>
    <div class="d-flex flex-wrap gap-3 align-items-start">
      <% if cover.present? %>
        <%= image_tag cover, alt: @album.name, class: "dash-thumb dash-thumb--lg" %>
      <% else %>
        <div class="dash-thumb dash-thumb--lg d-inline-flex align-items-center justify-content-center text-muted">
          <i class="fas fa-compact-disc fa-2x"></i>
        </div>
      <% end %>
      <div class="flex-grow-1">
        <h3 class="h5 mb-1" style="font-family: Syne, sans-serif; font-weight: 700;"><%= @album.name %></h3>
        <p class="text-muted mb-3"><%= @album.artist_name.presence || "Unknown artist" %></p>
        <div class="d-flex flex-wrap gap-2">
          <%= link_to "Edit album", edit_album_path(@album), class: "btn-dash-outline btn-sm" %>
          <%= link_to "All albums", admin_album_index_path, class: "btn-dash-outline btn-sm" %>
          <%= button_to "Delete album", @album, method: :delete,
                data: { confirm: "Delete this album and its associations?" },
                class: "btn-dash-danger btn-sm",
                form: { style: "display: inline;" } %>
        </div>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboards/panel", locals: {
        title: "Tracks on this album",
        action: link_to("Add tracks", new_track_path(album_id: @album.id), class: "btn-dash")
      } do %>
    <% if tracks.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Cover</th>
              <th>Title</th>
              <th>Artist</th>
              <th>Category</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% tracks.each do |track| %>
              <% thumb = shrine_image_url(track, :image, :thumbnail) || shrine_image_url(track, :image) %>
              <tr>
                <td>
                  <% if thumb.present? %>
                    <%= image_tag thumb, alt: track.title, class: "dash-thumb" %>
                  <% else %>
                    <div class="dash-thumb d-inline-flex align-items-center justify-content-center text-muted">
                      <i class="fas fa-music"></i>
                    </div>
                  <% end %>
                </td>
                <td><strong><%= track.title %></strong></td>
                <td><%= track.artist_name.presence || "—" %></td>
                <td>
                  <% if track.category.present? %>
                    <span class="dash-badge"><%= humanize_category(track.category) %></span>
                  <% else %>
                    —
                  <% end %>
                </td>
                <td>
                  <%= link_to "Edit", edit_track_path(track), class: "btn-dash-outline btn-sm me-1" %>
                  <%= button_to "Remove", track, method: :delete,
                        data: { confirm: "Remove this track?" },
                        class: "btn-dash-danger btn-sm",
                        form: { style: "display: inline;" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No tracks on this album yet.</p>
        <%= link_to "Add tracks", new_track_path(album_id: @album.id), class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
