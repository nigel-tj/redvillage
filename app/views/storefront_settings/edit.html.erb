<div class="dash">
  <%= render "dashboards/header",
        title: "Customize Storefront",
        eyebrow: @store.name,
        subtitle: "Colors, theme, logo, and branding.",
        primary_path: store_storefront_settings_path(@store),
        primary_label: "View Settings",
        primary_icon: "fas fa-eye",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Branding", padded: true } do %>
    <%= form_for [@store, @storefront_settings], html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @storefront_settings %>

      <div class="row g-3">
        <div class="col-md-4">
          <%= f.label :primary_color, "Primary color", class: "form-label" %>
          <%= f.color_field :primary_color, class: "form-control form-control-color", value: @storefront_settings.primary_color || "#ff6975" %>
        </div>
        <div class="col-md-4">
          <%= f.label :secondary_color, "Secondary color", class: "form-label" %>
          <%= f.color_field :secondary_color, class: "form-control form-control-color", value: @storefront_settings.secondary_color || "#03111e" %>
        </div>
        <div class="col-md-4">
          <%= f.label :accent_color, "Accent color", class: "form-label" %>
          <%= f.color_field :accent_color, class: "form-control form-control-color", value: @storefront_settings.accent_color || "#a730b2" %>
        </div>
        <div class="col-md-6">
          <%= f.label :theme, "Theme", class: "form-label" %>
          <%= f.select :theme, options_for_select(StorefrontSettings::THEMES.map { |t| [t.titleize, t] }, @storefront_settings.theme), {}, { class: "form-select" } %>
        </div>
        <div class="col-md-6">
          <%= f.label :font_family, "Font family", class: "form-label" %>
          <%= f.text_field :font_family, class: "form-control", placeholder: "Syne, sans-serif" %>
        </div>
        <div class="col-md-6">
          <%= render "shared/dash_upload",
                form: f,
                method: :logo,
                label: "Store logo",
                text: "Upload logo",
                hint: "PNG with transparency preferred",
                icon: "fas fa-image",
                current_url: (@storefront_settings.logo.present? ? @storefront_settings.logo : nil) %>
        </div>
        <div class="col-md-6">
          <%= render "shared/dash_upload",
                form: f,
                method: :banner_image,
                label: "Banner image",
                text: "Upload banner",
                hint: "Wide landscape works best",
                icon: "fas fa-image",
                current_url: (@storefront_settings.banner_image.present? ? @storefront_settings.banner_image : nil) %>
        </div>
        <div class="col-12">
          <%= f.label :custom_css, "Custom CSS", class: "form-label" %>
          <%= f.text_area :custom_css, class: "form-control", rows: 8, placeholder: ".custom-class { color: #d34d94; }" %>
        </div>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: store_storefront_settings_path(@store),
            submit_label: "Save Settings" %>
    <% end %>
  <% end %>
</div>
