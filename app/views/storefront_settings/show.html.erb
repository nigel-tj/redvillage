<div class="dash">
  <%= render "dashboards/header",
        title: "Storefront Settings",
        eyebrow: @store.name,
        subtitle: "Current branding and theme for this store.",
        primary_path: edit_store_storefront_settings_path(@store),
        primary_label: "Edit Settings",
        primary_icon: "fas fa-paint-brush",
        user: current_user %>

  <div class="row g-3">
    <div class="col-lg-8">
      <%= render layout: "dashboards/panel", locals: { title: "Color palette", padded: true } do %>
        <div class="row g-3">
          <div class="col-md-4">
            <div style="height: 100px; border-radius: 14px; background: <%= @storefront_settings.primary_color || '#ff6975' %>;"></div>
            <div class="small text-muted mt-2">Primary · <%= @storefront_settings.primary_color %></div>
          </div>
          <div class="col-md-4">
            <div style="height: 100px; border-radius: 14px; background: <%= @storefront_settings.secondary_color || '#03111e' %>;"></div>
            <div class="small text-muted mt-2">Secondary · <%= @storefront_settings.secondary_color %></div>
          </div>
          <div class="col-md-4">
            <div style="height: 100px; border-radius: 14px; background: <%= @storefront_settings.accent_color || '#a730b2' %>;"></div>
            <div class="small text-muted mt-2">Accent · <%= @storefront_settings.accent_color %></div>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-4">
          <%= link_to "Edit Settings", edit_store_storefront_settings_path(@store), class: "btn-dash" %>
          <%= link_to "Preview", preview_store_storefront_settings_path(@store), class: "btn-dash-outline", target: "_blank" %>
        </div>
      <% end %>
    </div>
    <div class="col-lg-4">
      <%= render layout: "dashboards/panel", locals: { title: "Current settings", padded: true } do %>
        <ul class="dash-feed">
          <li><span>Theme</span><strong><%= @storefront_settings.theme.to_s.titleize %></strong></li>
          <li><span>Font</span><strong><%= @storefront_settings.font_family.presence || "—" %></strong></li>
        </ul>
      <% end %>
    </div>
  </div>
</div>
