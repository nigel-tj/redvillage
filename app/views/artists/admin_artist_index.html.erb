<div class="dash">
  <%= render "dashboards/header",
        title: "All Artists",
        eyebrow: "Music & entertainment",
        subtitle: "Artist records and users with the artist role.",
        primary_path: new_artist_path,
        primary_label: "New Artist",
        primary_icon: "fas fa-user-plus",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Artist records", value: @artists_model.size, icon: "fas fa-id-badge" %>
    <%= render "dashboards/stat_card", label: "Artist users", value: @user_artists.size, icon: "fas fa-users" %>
    <%= render "dashboards/stat_card", label: "Total", value: @artists_model.size + @user_artists.size, icon: "fas fa-microphone" %>
  </div>

  <% if @artists_model.any? %>
    <%= render layout: "dashboards/panel", locals: {
          title: "Artist records",
          action: link_to("Add Artist", new_artist_path, class: "btn-dash")
        } do %>
      <div class="dash-media-grid">
        <% @artists_model.each do |artist| %>
          <% thumb = shrine_image_url(artist, :profile_picture, :thumbnail) || shrine_image_url(artist, :profile_picture) %>
          <div class="dash-media-card">
            <div class="dash-media-card__thumb">
              <% if thumb.present? %>
                <%= image_tag thumb, alt: artist.name %>
              <% else %>
                <i class="fas fa-user"></i>
              <% end %>
            </div>
            <div class="dash-media-card__body">
              <h3 class="dash-media-card__title"><%= artist.name %></h3>
              <% if artist.email.present? %>
                <p class="dash-media-card__meta"><%= artist.email %></p>
              <% end %>
              <% if artist.category.present? %>
                <span class="dash-badge align-self-start"><%= humanize_category(artist.category) %></span>
              <% end %>
              <div class="dash-media-card__actions">
                <%= link_to "Edit", edit_artist_path(artist), class: "btn-dash btn-sm" %>
                <%= button_to "Delete", artist, method: :delete,
                      data: { confirm: "Delete this artist?" },
                      class: "btn-dash-danger btn-sm",
                      form: { style: "display: inline;" } %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <% if @user_artists.any? %>
    <%= render layout: "dashboards/panel", locals: { title: "Users with artist role" } do %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Avatar</th>
              <th>Name</th>
              <th>Email</th>
              <th>Profile</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @user_artists.each do |user| %>
              <% img_url = user.profile&.profile_picture_url(:thumb) rescue nil %>
              <tr>
                <td>
                  <% if img_url.present? %>
                    <%= image_tag img_url, alt: user.name, class: "dash-thumb" %>
                  <% else %>
                    <div class="dash-thumb d-inline-flex align-items-center justify-content-center text-muted">
                      <i class="fas fa-user"></i>
                    </div>
                  <% end %>
                </td>
                <td><strong><%= user.name %></strong></td>
                <td><%= user.email %></td>
                <td>
                  <% if user.profile %>
                    <span class="dash-badge">Public profile</span>
                  <% else %>
                    <span class="text-muted">No profile</span>
                  <% end %>
                </td>
                <td>
                  <% if user.profile %>
                    <%= link_to "View", profile_path(user.profile), class: "btn-dash btn-sm me-1" %>
                  <% end %>
                  <%= link_to "Edit user", edit_user_path(user), class: "btn-dash-outline btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% end %>

  <% if @artists_model.empty? && @user_artists.empty? %>
    <%= render layout: "dashboards/panel", locals: { title: "Artists", padded: true } do %>
      <div class="dash-empty">
        <p>No artists found yet.</p>
        <%= link_to "Create New Artist", new_artist_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
