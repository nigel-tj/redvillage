<% content_for :title, "Artists — Red Village" %>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div class="rv-section-head text-start mb-0">
      <h1 class="rv-gradient-text">Artists</h1>
      <p class="rv-sub mb-0">Discover the creators behind Red Village.</p>
      <hr class="rv-rule rv-rule-start">
    </div>
    <%= link_to "Browse stores", stores_path, class: "btn btn-outline-rv btn-rv-sm" %>
  </div>

  <% artists = (@artists_model || []) + (@user_artists || []) %>

  <% if artists.any? %>
    <div class="row g-4">
      <% artists.each do |artist| %>
        <%
          if artist.is_a?(Artist)
            name      = artist.name
            link      = artist_path(artist)
            picture   = artist.profile_picture
            image_url = artist.profile_picture_url(:thumb) rescue nil
            subtitle  = artist.category.presence || "Artist"
          else
            name      = artist.name
            link      = profile_path(artist.profile)
            picture   = artist.profile&.profile_picture
            image_url = artist.profile&.profile_picture_url(:thumb) rescue nil
            subtitle  = artist.role.to_s.titleize
          end
        %>
        <div class="col-6 col-md-4 col-lg-3">
          <%= link_to link, class: "rv-event-tile text-decoration-none" do %>
            <div class="rv-event-tile__media">
              <% if picture.present? && image_url.present? %>
                <%= image_tag image_url, alt: name, class: "rv-event-tile__img" %>
              <% else %>
                <div class="rv-event-tile__placeholder d-flex align-items-center justify-content-center">
                  <span class="fw-bold" style="color:#ff8fbf;"><%= name.to_s.first(2).upcase %></span>
                </div>
              <% end %>
            </div>
            <div class="rv-event-tile__body">
              <h2 class="rv-event-tile__title h6"><%= name %></h2>
              <p class="small text-muted mb-0 mt-1"><%= subtitle %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted py-5 mb-0">No artists listed yet.</p>
  <% end %>
</div>
