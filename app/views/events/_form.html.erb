<%#
  Admin event form used by new/edit.
%>
<%= form_for @event, html: { multipart: true, class: "dash-form" } do |f| %>
  <%= render "shared/errors", object: @event %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true, placeholder: "Event name" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :date, class: "form-label" %>
      <%= f.date_field :date, class: "form-control", required: true %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :start_time, class: "form-label" %>
      <%= f.time_field :start_time, class: "form-control", required: true %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :venue, class: "form-label" %>
      <%= f.text_field :venue, class: "form-control", required: true, placeholder: "Venue" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :summary, class: "form-label" %>
    <%= f.text_area :summary, class: "form-control", required: true, rows: 4, placeholder: "Headlines and description" %>
  </div>

  <div class="mb-3">
    <% img_url = @event.persisted? ? (shrine_image_url(@event, :image, :thumbnail) || shrine_image_url(@event, :image)) : nil %>
    <% if @event.persisted? && @event.image.present? %>
      <%= f.hidden_field :image, value: @event.image_data %>
    <% end %>
    <%= render "shared/dash_upload",
          form: f,
          method: :image,
          label: "Event poster",
          hint: @event.persisted? ? "Leave empty to keep the current poster" : "JPG or PNG poster",
          current_url: img_url,
          required: @event.new_record? %>
  </div>

  <div class="dash-form__section">
    <h3 class="dash-form__section-title">Ticketing</h3>
    <div class="row">
      <div class="col-md-6 mb-3">
        <%= f.label :standard_ticket_price, class: "form-label" %>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
          <%= f.number_field :standard_ticket_price, class: "form-control", step: "0.01", min: "0", required: true, placeholder: "0.00" %>
        </div>
      </div>
      <div class="col-md-6 mb-3">
        <%= f.label :vip_ticket_price, class: "form-label" %>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
          <%= f.number_field :vip_ticket_price, class: "form-control", step: "0.01", min: "0", required: true, placeholder: "0.00" %>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <%= f.label :currency, class: "form-label" %>
        <%= f.select :currency,
              [
                ["USD ($)", "USD"], ["EUR (€)", "EUR"], ["GBP (£)", "GBP"],
                ["JPY (¥)", "JPY"], ["AUD (A$)", "AUD"], ["CAD (C$)", "CAD"],
                ["CHF (Fr)", "CHF"], ["CNY (¥)", "CNY"], ["INR (₹)", "INR"], ["ZAR (R)", "ZAR"]
              ],
              { selected: @event.currency.presence || "USD" },
              { class: "form-select" } %>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label">Options</label>
        <div class="form-check mt-2">
          <%= f.check_box :featured, class: "form-check-input" %>
          <%= f.label :featured, "Mark as featured event", class: "form-check-label" %>
        </div>
        <small class="form-text text-muted">Featured events appear on the featured events page</small>
      </div>
    </div>
  </div>

  <%= render "shared/dash_form_actions",
        form: f,
        cancel_path: admin_all_events_path,
        submit_label: @event.new_record? ? "Create Event" : "Update Event" %>
<% end %>
