<div class="dash">
  <%= render "shared/dash_page_header",
        title: "Events",
        eyebrow: "Calendar",
        subtitle: "Manage featured and upcoming events of the month.",
        primary_path: new_event_path,
        primary_label: "Add Event",
        primary_icon: "fas fa-calendar-plus",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Events", value: @events.size, icon: "fas fa-calendar-alt" %>
    <%= render "dashboards/stat_card",
          label: "Featured",
          value: @events.count(&:featured?),
          icon: "fas fa-star" %>
    <%= render "dashboards/stat_card",
          label: "Upcoming",
          value: @events.count { |e| e.date.present? && e.date >= Date.current },
          icon: "fas fa-clock" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Event catalog",
        action: link_to("Add Event", new_event_path, class: "btn-dash")
      } do %>
    <% if @events.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Poster</th>
              <th>Event</th>
              <th>Date</th>
              <th>Venue</th>
              <th>Tickets</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @events.each do |event| %>
              <% thumb = shrine_image_url(event, :image, :thumbnail) || shrine_image_url(event, :image) rescue nil %>
              <tr>
                <td>
                  <% if thumb.present? %>
                    <%= image_tag thumb, alt: event.name, class: "dash-thumb" %>
                  <% else %>
                    <div class="dash-thumb d-inline-flex align-items-center justify-content-center text-muted">
                      <i class="fas fa-calendar"></i>
                    </div>
                  <% end %>
                </td>
                <td>
                  <strong><%= event.name %></strong>
                  <% if event.featured? %>
                    <span class="dash-badge ms-1">Featured</span>
                  <% end %>
                  <% if event.summary.present? %>
                    <div class="text-muted small"><%= truncate(event.summary, length: 60) %></div>
                  <% end %>
                </td>
                <td>
                  <%= event.date&.strftime("%b %d, %Y") || "—" %>
                  <% if event.start_time.present? %>
                    <div class="text-muted small"><%= event.formatted_start_time %></div>
                  <% end %>
                </td>
                <td><%= event.venue.presence || "—" %></td>
                <td class="small">
                  <% if event.standard_ticket_price.present? %>
                    Std: <%= format_price(event.standard_ticket_price, event.currency) %><br>
                  <% end %>
                  <% if event.vip_ticket_price.present? %>
                    VIP: <%= format_price(event.vip_ticket_price, event.currency) %>
                  <% end %>
                  <% if event.standard_ticket_price.blank? && event.vip_ticket_price.blank? %>
                    —
                  <% end %>
                </td>
                <td>
                  <%= link_to "View", event_new_look_with_id_path(event.id), class: "btn-dash btn-sm me-1", target: "_blank", rel: "noopener" %>
                  <%= link_to "Edit", edit_event_path(event), class: "btn-dash-outline btn-sm me-1" %>
                  <%= button_to "Delete", event_path(event),
                        method: :delete,
                        form: { data: { turbo_confirm: "Delete this event?" }, class: "d-inline" },
                        class: "btn-dash-danger btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No events found.</p>
        <%= link_to "Create Your First Event", new_event_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
