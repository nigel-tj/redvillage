<% content_for :title, "Events — Red Village" %>

<div class="container py-4">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">Events</h1>
    <p class="rv-sub">Nights, festivals, and community gatherings near you.</p>
    <hr class="rv-rule">
  </div>

  <% if @events.present? %>
    <div class="row g-4 justify-content-center">
      <% @events.each do |event| %>
        <div class="col-sm-6 col-lg-4">
          <%= link_to event_path(event), class: "rv-event-tile text-decoration-none" do %>
            <% img = shrine_image_url(event, :image, :thumbnail) || shrine_image_url(event, :image) rescue nil %>
            <div class="rv-event-tile__media">
              <% if img.present? %>
                <%= image_tag img, alt: event.name, class: "rv-event-tile__img" %>
              <% else %>
                <div class="rv-event-tile__placeholder" aria-hidden="true"></div>
              <% end %>
            </div>
            <div class="rv-event-tile__body">
              <% if event.date.present? %>
                <time class="rv-event-tile__date" datetime="<%= event.date.iso8601 %>">
                  <%= event.date.strftime("%d %b %Y") %>
                </time>
              <% end %>
              <h2 class="rv-event-tile__title h5"><%= event.name %></h2>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted py-5 mb-0">No events published yet. Check back soon.</p>
  <% end %>
</div>
