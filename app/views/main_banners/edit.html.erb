<div class="dash">
  <%= render "shared/dash_page_header",
        title: "Edit Banner",
        eyebrow: "Design",
        subtitle: @banner.name,
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Banner details", padded: true } do %>
    <%= form_for @banner, html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @banner %>

      <div class="mb-3">
        <% img_url = shrine_image_url(@banner, :image, :thumbnail) || shrine_image_url(@banner, :image) %>
        <%= f.hidden_field :image, value: @banner.image_data %>
        <%= render "shared/dash_upload",
              form: f,
              method: :image,
              label: "Banner image",
              hint: "Leave empty to keep the current image",
              current_url: img_url %>
      </div>

      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true, placeholder: "Internal name" %>
      </div>

      <div class="mb-3">
        <%= f.label :title, "On-banner text", class: "form-label" %>
        <%= f.text_field :title, class: "form-control", required: true, placeholder: "Text shown on the banner" %>
      </div>

      <div class="mb-3">
        <%= f.label :page, class: "form-label" %>
        <%= f.select :page,
              [
                ["Select page", "none"],
                ["Home", "home"],
                ["Videos", "videos"],
                ["Music", "music"],
                ["Events", "events"],
                ["Artists", "artists"]
              ],
              {},
              { class: "form-select" } %>
      </div>

      <div class="mb-3">
        <label class="form-label">Options</label>
        <div class="form-check mt-2">
          <%= f.check_box :ticket_promo, class: "form-check-input" %>
          <%= f.label :ticket_promo, "Enable ticket booking and promo video section", class: "form-check-label" %>
        </div>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: main_banners_path,
            submit_label: "Update Banner" %>
    <% end %>
  <% end %>
</div>
