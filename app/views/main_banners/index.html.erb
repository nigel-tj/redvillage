<div class="dash">
  <%= render "shared/dash_page_header",
        title: "Banner Management",
        eyebrow: "Design",
        subtitle: "Hero banners for home, events, artists, and more.",
        primary_path: new_main_banner_path,
        primary_label: "Add Banner",
        primary_icon: "fas fa-image",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Banners", value: @banners.size, icon: "fas fa-images" %>
    <%= render "dashboards/stat_card",
          label: "Ticket Promo",
          value: @banners.count { |b| b.ticket_promo },
          icon: "fas fa-ticket-alt" %>
    <%= render "dashboards/stat_card",
          label: "Filtered",
          value: params[:page].present? ? humanize_category(params[:page]) : "All pages",
          icon: "fas fa-filter" %>
  </div>

  <%= render layout: "dashboards/panel", locals: { title: "Filter", padded: true } do %>
    <%= form_tag main_banners_path, method: :get, class: "dash-form row g-3 align-items-end" do %>
      <div class="col-md-4">
        <%= label_tag :page, "Page", class: "form-label" %>
        <%= select_tag :page,
              options_for_select([
                ["All Pages", ""],
                ["Home", "home"],
                ["Events", "events"],
                ["Artists", "artists"],
                ["Gallery", "gallery"],
                ["Videos", "videos"],
                ["Music", "music"]
              ], params[:page]),
              class: "form-select",
              onchange: "this.form.submit();" %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: {
        title: "Banners",
        action: link_to("Add Banner", new_main_banner_path, class: "btn-dash")
      } do %>
    <% if @banners.any? %>
      <div class="dash-media-grid">
        <% @banners.each do |banner| %>
          <% thumb = if banner.image_data?
                       banner.image[:thumbnail]&.url || banner.image[:original]&.url rescue nil
                     end %>
          <div class="dash-media-card">
            <div class="dash-media-card__thumb" style="aspect-ratio: 16 / 9;">
              <% if thumb.present? %>
                <%= image_tag thumb, alt: banner.name.to_s %>
              <% else %>
                <i class="fas fa-image"></i>
              <% end %>
            </div>
            <div class="dash-media-card__body">
              <h3 class="dash-media-card__title"><%= banner.name %></h3>
              <p class="dash-media-card__meta"><%= banner.title %></p>
              <p class="dash-media-card__meta">
                <span class="dash-badge"><%= banner.page&.titleize || "No page" %></span>
                <% if banner.ticket_promo %>
                  <span class="dash-badge">Ticket & Promo</span>
                <% end %>
              </p>
              <div class="dash-media-card__actions">
                <%= link_to "Edit", edit_main_banner_path(banner), class: "btn-dash-outline btn-sm" %>
                <%= button_to "Delete", main_banner_path(banner),
                      method: :delete,
                      form: { data: { turbo_confirm: "Delete this banner?" }, class: "d-inline" },
                      class: "btn-dash-danger btn-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No banners<%= " for this page" if params[:page].present? %>.</p>
        <%= link_to "Upload New Banner", new_main_banner_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
