<div class="container py-5">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">Contact Red Village</h1>
    <hr class="rv-rule">
    <p class="rv-sub">We're based in Harare and happy to help creators and fans alike.</p>
  </div>

  <div class="row g-4">
    <div class="col-lg-5 mb-4">
      <div class="card rv-card h-100">
        <div class="card-body">
          <h2 class="h5 fw-semibold mb-3">Get in touch</h2>
          <ul class="list-unstyled mb-0">
            <li class="mb-3"><i class="fas fa-map-marker-alt me-2" style="color:#ff1493;"></i> 1 Jason Moyo Avenue, Harare, Zimbabwe</li>
            <li class="mb-3"><i class="fas fa-phone me-2" style="color:#d34d94;"></i> +263 24 270 0000</li>
            <li class="mb-3"><i class="fas fa-envelope me-2" style="color:#a730b2;"></i> <a href="mailto:hello@redvillage.co.zw">hello@redvillage.co.zw</a></li>
            <li class="mb-3"><i class="fas fa-clock me-2" style="color:#7c3aed;"></i> Mon–Fri, 9:00–17:00 CAT</li>
          </ul>
          <hr>
          <p class="text-muted small mb-0">For store, event, or ticket support, include your store or event name so we can help faster.</p>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="card rv-card">
        <div class="card-body">
          <h2 class="h5 fw-semibold mb-3">Drop us a message</h2>
          <form action="/contact_us" method="post">
            <%= csrf_meta_tags %>
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" placeholder="Your name" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
              </div>
              <div class="col-12">
                <label class="form-label">Subject</label>
                <input type="text" name="subject" class="form-control" placeholder="How can we help?">
              </div>
              <div class="col-12">
                <label class="form-label">Message</label>
                <textarea name="message" class="form-control" rows="5" placeholder="Write your message" required></textarea>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-rv">Send message</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
