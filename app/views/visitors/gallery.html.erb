<div class="container py-5">
  <div class="row mb-4">
    <div class="col-12 text-center">
      <h1 class="fw-bold">Gallery</h1>
      <p class="text-muted">A visual showcase from Zimbabwe's creative community.</p>
    </div>
  </div>

  <% if @galleries.any? %>
    <% @galleries.each do |gallery| %>
      <div class="mb-5">
        <h2 class="h4 fw-semibold mb-3"><%= gallery.name.presence || "Gallery" %><% if gallery.category.present? %> <small class="text-muted fw-normal">· <%= gallery.category %></small><% end %></h2>
        <% if gallery.images.any? %>
          <div class="row g-3">
            <% gallery.images.each do |image| %>
              <div class="col-6 col-md-4 col-lg-3">
                <% if image.image_url.present? %>
                  <%= image_tag image.image_url, class: "img-fluid rounded shadow-sm w-100", style: "height:200px;object-fit:cover;", alt: image.name.to_s %>
                <% else %>
                  <div class="bg-light rounded d-flex align-items-center justify-content-center w-100" style="height:200px;">
                    <i class="fas fa-image fa-2x text-muted"></i>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% elsif gallery.image_url.present? %>
          <%= image_tag gallery.image_url, class: "img-fluid rounded shadow-sm", alt: gallery.name.to_s %>
        <% else %>
          <p class="text-muted">No images in this gallery yet.</p>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="col-12">
      <p class="text-center text-muted">The gallery is being curated. Check back soon!</p>
    </div>
  <% end %>
</div>
