<div class="container py-5">
  <div class="row mb-4">
    <div class="col-12 text-center">
      <h1 class="fw-bold">Blog & News</h1>
      <p class="text-muted">Stories, releases, and updates from the Red Village creative community.</p>
    </div>
  </div>

  <div class="row g-4">
    <% if @features.any? %>
      <% @features.each do |feature| %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">
            <% if feature.image_url.present? %>
              <%= image_tag feature.image_url, class: "card-img-top", style: "height:200px;object-fit:cover;", alt: feature.heading.to_s %>
            <% else %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                <i class="fas fa-newspaper fa-3x text-muted"></i>
              </div>
            <% end %>
            <div class="card-body d-flex flex-column">
              <h2 class="h5 card-title"><%= feature.heading.presence || "Red Village Update" %></h2>
              <p class="card-text text-muted flex-grow-1"><%= truncate(feature.intro.presence || feature.link.to_s, length: 140) %></p>
              <a href="<%= blog_details_path(id: feature.id) %>" class="btn btn-outline-primary mt-auto">Read more</a>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No posts yet. Check back soon!</p>
      </div>
    <% end %>
  </div>
</div>
