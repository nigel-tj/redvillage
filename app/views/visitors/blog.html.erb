<div class="container py-5">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">Blog & News</h1>
    <hr class="rv-rule">
    <p class="rv-sub">Stories, releases, and updates from the Red Village creative community.</p>
  </div>

  <div class="row g-4">
    <% if @features.any? %>
      <% @features.each do |feature| %>
        <div class="col-md-6 col-lg-4">
          <div class="card rv-card h-100">
            <% if feature.image_url.present? %>
              <%= image_tag feature.image_url, class: "rv-img", alt: feature.heading.to_s %>
            <% else %>
              <div class="rv-thumb-placeholder"><i class="fas fa-newspaper fa-3x"></i></div>
            <% end %>
            <div class="card-body d-flex flex-column">
              <h2 class="h5 card-title"><%= feature.heading.presence || "Red Village Update" %></h2>
              <p class="card-text text-muted flex-grow-1"><%= truncate(feature.intro.presence || feature.link.to_s, length: 140) %></p>
              <%= link_to "Read more", blog_details_path(id: feature.id), class: "btn btn-outline-rv mt-auto align-self-start" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No posts yet. Check back soon!</p>
      </div>
    <% end %>
  </div>
</div>
