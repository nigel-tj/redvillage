<div class="container py-5">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <% if @feature.present? %>
        <article>
          <h1 class="rv-gradient-text fw-bold mb-3"><%= @feature.heading.presence || "Red Village Update" %></h1>
          <p class="text-muted"><i class="far fa-calendar me-1"></i> <%= @feature.created_at.strftime("%B %d, %Y") %></p>
          <% if @feature.image_url.present? %>
            <%= image_tag @feature.image_url, class: "img-fluid rounded shadow-sm mb-4", alt: @feature.heading.to_s %>
          <% end %>
          <div class="lead mb-4"><%= @feature.intro.presence || @feature.link %></div>
          <% if @feature.link.present? %>
            <a href="<%= @feature.link %>" target="_blank" rel="noopener" class="btn btn-rv">Read the full story</a>
          <% end %>
        </article>
      <% else %>
        <p class="text-center text-muted">Post not found.</p>
      <% end %>

      <hr class="my-5">
      <h2 class="h5 mb-3">More posts</h2>
      <div class="row g-3">
        <% @features.reject { |f| f == @feature }.first(3).each do |feature| %>
          <div class="col-md-4">
            <div class="card rv-card h-100">
              <div class="card-body">
                <h3 class="h6 card-title"><%= link_to (feature.heading.presence || "Red Village Update"), blog_details_path(id: feature.id), class: "text-decoration-none" %></h3>
                <p class="card-text text-muted small"><%= truncate(feature.intro.presence || feature.link.to_s, length: 80) %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="mt-4">
        <%= link_to "← Back to Blog", blog_path, class: "btn btn-outline-rv" %>
      </div>
    </div>
  </div>
</div>
