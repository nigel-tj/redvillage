<% content_for :title, "Team — Red Village" %>

<div class="container py-4">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">Our Team</h1>
    <p class="rv-sub">The creators behind Red Village — DJs, artists, photographers, and more.</p>
    <hr class="rv-rule">
  </div>

  <%
    sections = [
      ["Our DJs", @djs],
      ["Our Artists", @artists],
      ["Our Photographers", @photographers],
      ["Our Videographers", @videographers],
      ["Our Curators", @curators],
      ["Our Designers", @designers],
      ["Our Editors", @editors]
    ]
  %>

  <% any = false %>
  <% sections.each do |title, members| %>
    <% next if members.blank? %>
    <% any = true %>
    <div class="mb-5">
      <h2 class="h4 fw-bold text-center mb-4"><%= title %></h2>
      <div class="row creator-flex">
        <% members.each do |member| %>
          <%= render "profiles_listings/profile_card", profile: member.profile, user: member %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% unless any %>
    <p class="text-center text-muted py-5 mb-0">No team members with public profiles yet. Check back soon!</p>
  <% end %>
</div>

<%= render "visitors/testimonials" %>

<div class="container py-4 pb-5">
  <div class="rv-cta rounded-4 p-4 p-md-5 text-center text-white">
    <h2 class="h3 fw-bold mb-2">Join Our Team</h2>
    <p class="mb-4 opacity-90">We&rsquo;re always looking for talented people to grow the village.</p>
    <%= link_to "Get in touch", contact_us_path, class: "btn btn-light btn-lg px-4" %>
  </div>
</div>
