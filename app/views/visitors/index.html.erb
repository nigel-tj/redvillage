<% content_for :title, "Red Village — Creative Marketplace" %>
<% content_for :full_bleed, true %>

<% hero_banner = @banners&.detect { |b| shrine_image_url(b, :image, :original).present? } || @banners&.first %>
<% hero_img = hero_banner && shrine_image_url(hero_banner, :image, :original) %>

<section class="rv-home-hero<%= ' rv-home-hero--photo' if hero_img %>"
         <% if hero_img %>style="--rv-hero-image: url('<%= hero_img %>')"<% end %>>
  <div class="rv-home-hero__veil" aria-hidden="true"></div>
  <div class="container rv-home-hero__inner">
    <p class="rv-home-brand rv-reveal" style="--rv-delay: 0ms">RED VILLAGE</p>
    <h1 class="rv-home-headline rv-reveal" style="--rv-delay: 80ms">
      A creative marketplace
    </h1>
    <p class="rv-home-lede rv-reveal" style="--rv-delay: 160ms">
      Discover events, music, galleries, and maker stores — from local studios to the global stage.
    </p>
    <div class="rv-home-cta rv-reveal" style="--rv-delay: 240ms">
      <%= link_to "Browse events", events_path, class: "btn btn-rv" %>
      <%= link_to "Explore stores", stores_path, class: "btn btn-outline-rv" %>
    </div>
  </div>
</section>

<section class="rv-home-section">
  <div class="container">
    <div class="rv-section-head rv-reveal">
      <h2 class="rv-gradient-text">Coming up</h2>
      <p class="rv-sub">Nights, showcases, and community gatherings on the calendar.</p>
      <hr class="rv-rule">
    </div>

    <% if @events.present? %>
      <div class="row g-4 justify-content-center">
        <% @events.each_with_index do |event, i| %>
          <div class="col-sm-6 col-lg-4 rv-reveal" style="--rv-delay: <%= i * 60 %>ms">
            <%= link_to event_path(event), class: "rv-event-tile text-decoration-none" do %>
              <% img = shrine_image_url(event, :image, :thumbnail) || shrine_image_url(event, :image) rescue nil %>
              <div class="rv-event-tile__media">
                <% if img.present? %>
                  <%= image_tag img, alt: event.name, class: "rv-event-tile__img" %>
                <% else %>
                  <div class="rv-event-tile__placeholder" aria-hidden="true"></div>
                <% end %>
              </div>
              <div class="rv-event-tile__body">
                <% if event.date.present? %>
                  <time class="rv-event-tile__date" datetime="<%= event.date.iso8601 %>">
                    <%= event.date.strftime("%d %b %Y") %>
                  </time>
                <% end %>
                <h3 class="rv-event-tile__title"><%= event.name %></h3>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="text-center mt-4">
        <%= link_to "All events", events_path, class: "btn btn-outline-rv btn-rv-sm" %>
      </div>
    <% else %>
      <p class="text-center text-muted mb-0">New events will land here soon. Check back, or follow the community on social.</p>
    <% end %>
  </div>
</section>

<section class="rv-home-section rv-home-section--alt">
  <div class="container">
    <div class="rv-section-head">
      <h2 class="rv-gradient-text">Explore the village</h2>
      <p class="rv-sub">One place for music, visuals, and maker storefronts.</p>
      <hr class="rv-rule">
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <%= link_to "/music", class: "rv-explore-link" do %>
          <span class="rv-explore-link__label">Music</span>
          <span class="rv-explore-link__hint">Tracks &amp; albums from local artists</span>
        <% end %>
      </div>
      <div class="col-md-4">
        <%= link_to "/gallery", class: "rv-explore-link" do %>
          <span class="rv-explore-link__label">Gallery</span>
          <span class="rv-explore-link__hint">Photography &amp; visual stories</span>
        <% end %>
      </div>
      <div class="col-md-4">
        <%= link_to malls_path, class: "rv-explore-link" do %>
          <span class="rv-explore-link__label">Malls</span>
          <span class="rv-explore-link__hint">Shared storefronts for makers</span>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section class="rv-home-section">
  <%= render "visitors/testimonials" %>
</section>

<section class="rv-home-section pb-5">
  <div class="container">
    <div class="rv-cta rounded-4 p-4 p-md-5 text-center text-white">
      <h2 class="h3 fw-bold mb-2">Create with Red Village</h2>
      <p class="mb-4 opacity-90 mx-auto" style="max-width: 36rem;">
        Open a store, publish events, or build a public creator profile.
      </p>
      <%= link_to "Join the community", new_user_registration_path, class: "btn btn-light btn-lg px-4" %>
    </div>
  </div>
</section>
