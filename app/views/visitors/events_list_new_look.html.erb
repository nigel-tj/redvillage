<div class="container py-5">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">All Events</h1>
    <hr class="rv-rule">
    <p class="rv-sub">Everything on the Red Village calendar.</p>
  </div>

  <div class="row g-4">
    <% if @events.any? %>
      <% @events.each do |event| %>
        <div class="col-md-6 col-lg-4">
          <div class="card rv-card h-100">
            <% if event.image_url.present? %>
              <%= image_tag event.image_url, class: "rv-img", alt: event.name.to_s %>
            <% else %>
              <div class="rv-thumb-placeholder"><i class="fas fa-calendar-alt fa-3x"></i></div>
            <% end %>
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h2 class="h5 card-title mb-0"><%= event.name.presence || "Untitled Event" %></h2>
                <% if event.featured %><span class="badge rounded-pill mt-1" style="background:#ff1493;">Featured</span><% end %>
              </div>
              <p class="text-muted small mb-1">
                <i class="far fa-calendar me-1"></i>
                <%= event.date.present? ? event.date.strftime("%B %d, %Y") : "Date TBA" %>
                <% if event.start_time.present? %><span class="ms-2"><i class="far fa-clock me-1"></i><%= event.start_time %></span><% end %>
              </p>
              <% if event.venue.present? %>
                <p class="text-muted small mb-2"><i class="fas fa-map-marker-alt me-1"></i> <%= event.venue %></p>
              <% end %>
              <% if event.summary.present? %>
                <p class="card-text text-muted flex-grow-1"><%= truncate(event.summary, length: 120) %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No events scheduled yet. Check back soon!</p>
      </div>
    <% end %>
  </div>
</div>
