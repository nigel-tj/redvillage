<div class="container py-5">
  <div class="row mb-4">
    <div class="col-12 text-center">
      <h1 class="fw-bold">All Events</h1>
      <p class="text-muted">Everything on the Red Village calendar.</p>
    </div>
  </div>

  <div class="row g-4">
    <% if @events.any? %>
      <% @events.each do |event| %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">
            <% if event.image_url.present? %>
              <%= image_tag event.image_url, class: "card-img-top", style: "height:180px;object-fit:cover;", alt: event.name.to_s %>
            <% else %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:180px;">
                <i class="fas fa-calendar-alt fa-3x text-muted"></i>
              </div>
            <% end %>
            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h2 class="h5 card-title mb-0"><%= event.name.presence || "Untitled Event" %></h2>
                <% if event.featured %><span class="badge bg-warning text-dark ms-2">Featured</span><% end %>
              </div>
              <p class="text-muted small mb-1">
                <i class="far fa-calendar me-1"></i>
                <%= event.date.present? ? event.date.strftime("%B %d, %Y") : "Date TBA" %>
                <% if event.start_time.present? %><span class="ms-2"><i class="far fa-clock me-1"></i><%= event.start_time %></span><% end %>
              </p>
              <% if event.venue.present? %>
                <p class="text-muted small mb-2"><i class="fas fa-map-marker-alt me-1"></i> <%= event.venue %></p>
              <% end %>
              <% if event.summary.present? %>
                <p class="card-text text-muted flex-grow-1"><%= truncate(event.summary, length: 120) %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No events scheduled yet. Check back soon!</p>
      </div>
    <% end %>
  </div>
</div>
