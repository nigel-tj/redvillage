<div class="container py-5">
  <div class="rv-hero text-center">
    <h1 class="fw-bold">Top DJs</h1>
    <p class="rv-sub mx-auto">The world's spins — browse public DJ profiles and their work.</p>
  </div>

  <div class="row g-4 mb-5">
    <% if @djs.any? %>
      <% @djs.each do |dj| %>
        <%= render 'profiles_listings/profile_card', profile: dj.profile, user: dj %>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No DJs with public profiles yet. Check back soon!</p>
      </div>
    <% end %>
  </div>

  <div class="rv-section-head mt-4">
    <h2 class="rv-gradient-text">About Red Village</h2>
    <hr class="rv-rule rv-rule-start">
  </div>
  <div class="row mt-3 align-items-center mb-4">
    <div class="col-lg-8">
      <p>Red Village is a creative marketplace for music, art, and makers everywhere.
        From local studios to the festival stage, we connect DJs, artists, photographers,
        videographers, curators, designers, and editors with the audiences who love their work.</p>
      <a href="/creators" class="btn btn-outline-rv">Meet our creators</a>
    </div>
  </div>
</div>

<%= render "visitors/testimonials" %>
