<div class="container py-5">
  <div class="row mb-4">
    <div class="col-12 text-center">
      <h1 class="fw-bold">Top DJs</h1>
      <p class="text-muted">Zimbabwe's spins — browse public DJ profiles and their work.</p>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <% if @djs.any? %>
      <% @djs.each do |dj| %>
        <%= render 'profiles_listings/profile_card', profile: dj.profile, user: dj %>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No DJs with public profiles yet. Check back soon!</p>
      </div>
    <% end %>
  </div>

  <% if @djs.any? %>
    <h2 class="h4 fw-semibold mb-3">From Our Community</h2>
    <div class="row g-4">
      <% @djs.first(3).each do |dj| %>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h3 class="h5 card-title"><%= dj.name %></h3>
              <p class="text-muted small mb-2"><%= dj.profile&.role_display %></p>
              <p class="card-text"><%= truncate(dj.profile&.bio.presence || "Part of the Red Village creative community.", length: 160) %></p>
              <% if dj.profile.present? %>
                <%= link_to "View Profile", profile_path(dj.profile), class: "btn btn-sm btn-primary mt-2" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="row mt-5 align-items-center">
    <div class="col-lg-6">
      <h2 class="h4 fw-semibold">About Red Village</h2>
      <p>Red Village is a creative marketplace for Zimbabwean music, art, and makers.
        From Harare's studios to the festival stage, we connect DJs, artists, photographers,
        videographers, curators, designers, and editors with the audiences who love their work.</p>
      <a href="/creators" class="btn btn-outline-primary">Meet our creators</a>
    </div>
  </div>
</div>
