<div class="container py-5">
  <div class="rv-hero text-center">
    <h1 class="fw-bold">Top DJs</h1>
    <p class="rv-sub mx-auto">Zimbabwe's spins — browse public DJ profiles and their work.</p>
  </div>

  <div class="row g-4 mb-5">
    <% if @djs.any? %>
      <% @djs.each do |dj| %>
        <%= render 'profiles_listings/profile_card', profile: dj.profile, user: dj %>
      <% end %>
    <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No DJs with public profiles yet. Check back soon!</p>
      </div>
    <% end %>
  </div>

  <% if @djs.any? %>
    <div class="rv-section-head">
      <h2 class="rv-gradient-text">From Our Community</h2>
      <hr class="rv-rule">
    </div>
    <div class="row g-4">
      <% @djs.first(3).each do |dj| %>
        <div class="col-md-4">
          <div class="card rv-card h-100">
            <div class="card-body">
              <h3 class="h5 card-title"><%= dj.name %></h3>
              <p class="text-muted small mb-2"><%= dj.profile&.role_display %></p>
              <p class="card-text"><%= truncate(dj.profile&.bio.presence || "Part of the Red Village creative community.", length: 160) %></p>
              <% if dj.profile.present? %>
                <%= link_to "View Profile", profile_path(dj.profile), class: "btn btn-rv btn-rv-sm mt-2" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="rv-section-head mt-5">
    <h2 class="rv-gradient-text">About Red Village</h2>
    <hr class="rv-rule rv-rule-start">
  </div>
  <div class="row mt-3 align-items-center">
    <div class="col-lg-8">
      <p>Red Village is a creative marketplace for Zimbabwean music, art, and makers.
        From Harare's studios to the festival stage, we connect DJs, artists, photographers,
        videographers, curators, designers, and editors with the audiences who love their work.</p>
      <a href="/creators" class="btn btn-outline-rv">Meet our creators</a>
    </div>
  </div>
</div>
