    <!-- breadcrump begin -->
    <div class="breadcrump">
        <div class="container">
            <div class="row">
                <div class="col-xl-6 col-lg-6">
                    <%= render_breadcrumbs %>
                </div>
            </div>
        </div>
    </div>
    <!-- breadcrump end -->

    <!-- team dj begin -->
    <div class="team-dj top-dj-page">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-8 col-lg-8">
                    <div class="add-space section-title text-center">
                        <h2>Top DJs</h2>
                    </div>
                </div>
            </div>
            <div class="row">
                <% if @djs.any? %>
                    <% @djs.each do |dj| %>
                        <%= render 'profiles_listings/profile_card', profile: dj.profile, user: dj %>
                    <% end %>
                <% else %>
                    <div class="col-12">
                        <p class="text-center text-muted">No DJs with public profiles yet. Check back soon!</p>
                    </div>
                <% end %>
            </div>
        </div>
    </div>
    <!-- team dj end -->

    <!-- testimonial begin -->
    <div class="testimonial">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-8 col-lg-8">
                    <div class="section-title text-center">
                        <h2>From Our Community</h2>
                    </div>
                </div>
            </div>
            <div class="row">
                <% if @djs.any? %>
                    <% @djs.first(3).each do |dj| %>
                        <div class="col-xl-4 col-lg-4 col-md-6 col-12 mb-4">
                            <div class="single-testimonial p-4 border rounded bg-white h-100">
                                <div class="part-text">
                                    <div class="bio mb-2">
                                        <span class="name font-weight-bold"><%= dj.name %></span>
                                        <span class="position text-muted small d-block"><%= dj.profile&.role_display %></span>
                                    </div>
                                    <div class="text">
                                        <p class="mb-0"><%= truncate(dj.profile&.bio.presence || "Part of the Red Village creative community.", length: 160) %></p>
                                    </div>
                                    <% if dj.profile.present? %>
                                        <div class="mt-3">
                                            <%= link_to "View Profile", profile_path(dj.profile), class: "btn btn-sm btn-primary" %>
                                        </div>
                                    <% end %>
                                </div>
                            </div>
                        </div>
                    <% end %>
                <% else %>
                    <div class="col-12">
                        <p class="text-center text-muted">No community stories yet. Check back soon!</p>
                    </div>
                <% end %>
            </div>
        </div>
    </div>
    <!-- testimonial end -->

    <!-- about begin -->
    <div class="about">
        <div class="container">
            <div class="row">
                <div class="col-xl-12 col-lg-12">
                    <div class="about-area">
                        <div class="row no-gutters">
                            <div class="col-xl-6 col-lg-6">
                                <div class="part-text">
                                    <h2>About Red Village</h2>
                                    <p>Red Village is a creative marketplace for Zimbabwean music,
                                        art, and makers. From Harare's studios to the festival stage,
                                        we connect DJs, artists, photographers, videographers, curators,
                                        designers, and editors with the audiences who love their work.</p>
                                    <a href="/creators">Meet our creators</a>
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6 d-xl-block d-lg-block d-none"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- about end -->