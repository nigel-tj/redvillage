<div class="dash">
  <%= render "dashboards/header",
        title: "Order ##{@order.id}",
        eyebrow: @store.name,
        subtitle: "Placed #{@order.created_at.strftime('%B %d, %Y at %I:%M %p')}",
        primary_path: store_orders_path(@store),
        primary_label: "All Orders",
        primary_icon: "fas fa-list",
        user: current_user %>

  <div class="row g-3">
    <div class="col-lg-8">
      <%= render layout: "dashboards/panel", locals: {
            title: "Order items",
            action: (tag.span @order.status.titleize, class: "dash-badge")
          } do %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% @order_items.each do |item| %>
                <tr>
                  <td>
                    <%= link_to item.product.name, store_product_path(@store, item.product), class: "text-decoration-none fw-bold" %>
                  </td>
                  <td><%= item.quantity %></td>
                  <td>$<%= sprintf("%.2f", item.unit_price || item.product.price) %></td>
                  <td>$<%= sprintf("%.2f", item.total_price || (item.quantity * item.unit_price)) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

      <%= render layout: "dashboards/panel", locals: { title: "Shipping", padded: true } do %>
        <p class="mb-0">
          <strong><%= @order.shipping_name %></strong><br>
          <%= simple_format(@order.shipping_address) %>
          <% if @order.shipping_phone.present? %>
            <br>Phone: <%= @order.shipping_phone %>
          <% end %>
        </p>
        <% if @order.billing_address.present? && @order.billing_address != @order.shipping_address %>
          <hr>
          <div class="small text-muted text-uppercase fw-bold mb-1">Billing</div>
          <%= simple_format(@order.billing_address) %>
        <% end %>
      <% end %>
    </div>

    <div class="col-lg-4">
      <%= render layout: "dashboards/panel", locals: { title: "Summary", padded: true } do %>
        <ul class="dash-feed">
          <li><span>Subtotal</span><span><%= @order.formatted_total %></span></li>
          <li><span><strong>Total</strong></span><strong style="color:#a730b2;">$<%= sprintf("%.2f", @order.total_amount) %></strong></li>
        </ul>
        <% if @payment %>
          <div class="mt-3">
            <div class="small text-muted text-uppercase fw-bold">Payment</div>
            <% case @payment.status
               when "succeeded", "paid" %>
              <span class="dash-badge dash-badge--ok">Paid</span>
            <% when "failed" %>
              <span class="dash-badge dash-badge--danger">Failed</span>
            <% else %>
              <span class="dash-badge dash-badge--warn">Pending</span>
            <% end %>
          </div>
        <% end %>
        <div class="d-grid gap-2 mt-3">
          <%= link_to "Back to products", store_products_path(@store), class: "btn-dash-outline" %>
          <% if @store.owner?(current_user) || current_user&.admin? %>
            <%= link_to "All orders", store_orders_path(@store), class: "btn-dash-ghost" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
