<% content_for :title, "Music — Red Village" %>

<div class="container py-4">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">Music</h1>
    <p class="rv-sub">Tracks and albums from independent artists on Red Village.</p>
    <hr class="rv-rule">
  </div>

  <% tracks = @tracks.to_a %>
  <% albums = @albums.to_a %>

  <% if tracks.any? %>
    <h2 class="h4 fw-bold mb-3">Tracks</h2>
    <div class="row g-4 mb-5">
      <% tracks.each do |track| %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card rv-card h-100">
            <% img = (track.respond_to?(:image) && track.image.present?) ? (track.image_url(:thumb) rescue track.image_url) : nil %>
            <% if img.present? %>
              <%= image_tag img, alt: track.title, class: "rv-img" %>
            <% else %>
              <div class="rv-thumb-placeholder"><i class="fas fa-music fa-2x"></i></div>
            <% end %>
            <div class="card-body">
              <h3 class="h6 card-title mb-1"><%= track.title %></h3>
              <% if track.respond_to?(:artist_name) && track.artist_name.present? %>
                <p class="text-muted small mb-0"><%= track.artist_name %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if albums.any? %>
    <h2 class="h4 fw-bold mb-3">Albums &amp; mixtapes</h2>
    <div class="row g-4">
      <% albums.each do |album| %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card rv-card h-100">
            <% img = (album.respond_to?(:image) && album.image.present?) ? (album.image_url(:thumb) rescue album.image_url) : nil %>
            <% if img.present? %>
              <%= image_tag img, alt: album.name, class: "rv-img" %>
            <% else %>
              <div class="rv-thumb-placeholder"><i class="fas fa-compact-disc fa-2x"></i></div>
            <% end %>
            <div class="card-body">
              <h3 class="h6 card-title mb-0"><%= album.name %></h3>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if tracks.empty? && albums.empty? %>
    <p class="text-center text-muted py-5 mb-0">No music published yet. Check back soon.</p>
  <% end %>
</div>
