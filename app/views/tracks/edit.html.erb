<% thumb = shrine_image_url(@track, :image, :thumbnail) || shrine_image_url(@track, :image) %>

<div class="dash">
  <%= render "dashboards/header",
        title: "Edit Track",
        eyebrow: "Music & entertainment",
        subtitle: "Update #{@track.title}.",
        primary_path: admin_all_music_path,
        primary_label: "All Music",
        primary_icon: "fas fa-list",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Track details", padded: true } do %>
    <%= form_for @track, html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @track %>

      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :title, "Track title", class: "form-label" %>
          <%= f.text_field :title, class: "form-control", required: true, placeholder: "Track title" %>
        </div>
        <div class="col-md-6">
          <%= f.label :category, "Category", class: "form-label" %>
          <%= f.select :category,
                [["Select category", ""], ["RCV Playlist", "rcv_playlist"], ["Albums / Mixtapes", "albums_mixtapes"]],
                { selected: @track.category },
                { class: "form-select" } %>
        </div>
        <div class="col-md-6">
          <%= f.label :image, "Cover image", class: "form-label" %>
          <% if thumb.present? %>
            <div class="dash-upload__preview mb-2">
              <%= image_tag thumb, alt: @track.title %>
            </div>
          <% end %>
          <label class="dash-upload">
            <span class="dash-upload__icon"><i class="fas fa-image"></i></span>
            <span class="dash-upload__text"><%= thumb.present? ? "Replace cover image" : "Drop cover or click to browse" %></span>
            <span class="dash-upload__hint">Leave empty to keep current cover</span>
            <%= f.hidden_field :image_cache %>
            <%= f.file_field :image, class: "dash-upload__input", accept: "image/*" %>
          </label>
        </div>
        <div class="col-md-6">
          <%= f.label :track, "Audio file", class: "form-label" %>
          <% if @track.track.present? %>
            <p class="form-text mb-2">Current file attached for <strong><%= @track.title %></strong></p>
          <% end %>
          <label class="dash-upload">
            <span class="dash-upload__icon"><i class="fas fa-file-audio"></i></span>
            <span class="dash-upload__text">Replace audio file</span>
            <span class="dash-upload__hint">Leave empty to keep current track</span>
            <%= f.file_field :track, class: "dash-upload__input", accept: "audio/*" %>
          </label>
        </div>
      </div>

      <div class="dash-form__actions">
        <%= link_to "Cancel", admin_all_music_path, class: "btn-dash-outline" %>
        <%= f.submit "Update Track", class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
