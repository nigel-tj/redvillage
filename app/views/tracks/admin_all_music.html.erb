<div class="dash">
  <%= render "dashboards/header",
        title: "All Music",
        eyebrow: "Music & entertainment",
        subtitle: "Full music library for managers and artists.",
        primary_path: new_track_path,
        primary_label: "Upload Track",
        primary_icon: "fas fa-upload",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Total Tracks", value: @tracks.size, icon: "fas fa-music" %>
    <%= render "dashboards/stat_card", label: "With Cover", value: @tracks.count { |t| t.image.present? }, icon: "fas fa-image" %>
    <%= render "dashboards/stat_card", label: "On Albums", value: @tracks.count { |t| t.album_id.present? }, icon: "fas fa-layer-group" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Music library",
        action: link_to("New Track", new_track_path, class: "btn-dash")
      } do %>
    <% if @tracks.any? %>
      <div class="dash-media-grid">
        <% @tracks.each do |track| %>
          <% thumb = shrine_image_url(track, :image, :thumbnail) || shrine_image_url(track, :image) %>
          <div class="dash-media-card">
            <div class="dash-media-card__thumb">
              <% if thumb.present? %>
                <%= image_tag thumb, alt: track.title %>
              <% else %>
                <i class="fas fa-music"></i>
              <% end %>
            </div>
            <div class="dash-media-card__body">
              <h3 class="dash-media-card__title"><%= track.title %></h3>
              <p class="dash-media-card__meta"><%= track.artist_name.presence || "Unknown artist" %></p>
              <% if track.category.present? %>
                <span class="dash-badge align-self-start"><%= humanize_category(track.category) %></span>
              <% end %>
              <div class="dash-media-card__actions">
                <%= link_to "Edit", edit_track_path(track), class: "btn-dash btn-sm" %>
                <%= button_to "Delete", track, method: :delete,
                      data: { confirm: "Delete this track?" },
                      class: "btn-dash-danger btn-sm",
                      form: { style: "display: inline;" } %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No music in the library yet.</p>
        <%= link_to "Upload New Track", new_track_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
