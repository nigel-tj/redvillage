<div class="dash">
  <%= render "dashboards/header",
        title: "All Tracks",
        eyebrow: "Music & entertainment",
        subtitle: "Manage uploaded tracks across the catalog.",
        primary_path: new_track_path,
        primary_label: "Upload Track",
        primary_icon: "fas fa-upload",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Tracks", value: @tracks.size, icon: "fas fa-music" %>
    <%= render "dashboards/stat_card", label: "Artists", value: (@artists&.size || @tracks.map(&:artist_name).compact.uniq.size), icon: "fas fa-microphone" %>
    <%= render "dashboards/stat_card", label: "Albums linked", value: @tracks.count { |t| t.album_id.present? }, icon: "fas fa-compact-disc" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Track library",
        action: link_to("Upload New Track", new_track_path, class: "btn-dash")
      } do %>
    <% if @tracks.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Cover</th>
              <th>Title</th>
              <th>Artist</th>
              <th>Album</th>
              <th>Category</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @tracks.each do |track| %>
              <% thumb = shrine_image_url(track, :image, :thumbnail) || shrine_image_url(track, :image) %>
              <tr>
                <td>
                  <% if thumb.present? %>
                    <%= image_tag thumb, alt: track.title, class: "dash-thumb" %>
                  <% else %>
                    <div class="dash-thumb d-inline-flex align-items-center justify-content-center text-muted">
                      <i class="fas fa-music"></i>
                    </div>
                  <% end %>
                </td>
                <td><strong><%= track.title %></strong></td>
                <td><%= track.artist_name.presence || "—" %></td>
                <td><%= track.album&.name || "—" %></td>
                <td>
                  <% if track.category.present? %>
                    <span class="dash-badge"><%= humanize_category(track.category) %></span>
                  <% else %>
                    —
                  <% end %>
                </td>
                <td><%= time_ago_in_words(track.created_at) %> ago</td>
                <td>
                  <%= link_to "Edit", edit_track_path(track), class: "btn-dash-outline btn-sm me-1" %>
                  <%= button_to "Delete", track, method: :delete,
                        data: { confirm: "Delete this track?" },
                        class: "btn-dash-danger btn-sm",
                        form: { style: "display: inline;" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No tracks uploaded yet.</p>
        <%= link_to "Upload Your First Track", new_track_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
