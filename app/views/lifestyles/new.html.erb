<div class="dash">
  <%= render "shared/dash_page_header",
        title: "New Lifestyle Article",
        eyebrow: "Editorial",
        subtitle: "Add a lifestyle story to the catalog.",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Article details", padded: true } do %>
    <%= form_for @lifestyle, html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @lifestyle %>

      <div class="mb-3">
        <%= f.label :title, class: "form-label" %>
        <%= f.text_field :title, class: "form-control", required: true, placeholder: "Article title" %>
      </div>

      <div class="mb-3">
        <%= render "shared/dash_upload",
              form: f,
              method: :image,
              label: "Article image",
              hint: "JPG or PNG",
              required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :category, class: "form-label" %>
        <%= f.select :category,
              [
                ["Select category", "none"],
                ["Fashion", "fashion"],
                ["Healthy Living", "healthyLiving"],
                ["Street Hustle", "streetHustle"],
                ["Gadgets", "gadgets"]
              ],
              {},
              { class: "form-select" } %>
      </div>

      <div class="mb-3">
        <%= f.label :intro, class: "form-label" %>
        <%= f.text_area :intro, class: "form-control", required: true, id: "word_count", rows: 4, placeholder: "Short introduction" %>
        <div class="form-text mt-1">
          Words: <span id="display_count">0</span> · Left: <span id="word_left">20</span> (max 20)
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :link, "Article URL", class: "form-label" %>
        <%= f.text_field :link, class: "form-control", required: true, placeholder: "https://" %>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: "/lifestyle_admin_index",
            submit_label: "Create Article" %>
    <% end %>
  <% end %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var input = document.getElementById("word_count");
    if (!input) return;
    input.addEventListener("keyup", function () {
      var words = (this.value.match(/\S+/g) || []).length;
      if (words > 20) {
        this.value = this.value.split(/\s+/).slice(0, 20).join(" ") + " ";
        words = 20;
      }
      document.getElementById("display_count").textContent = words;
      document.getElementById("word_left").textContent = 20 - words;
    });
  });
</script>
