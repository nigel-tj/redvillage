<div class="dash">
  <%= render "shared/dash_page_header",
        title: "News & Features",
        eyebrow: "Editorial",
        subtitle: "Curate featured stories shown across the site.",
        primary_path: new_feature_path,
        primary_label: "Add Feature",
        primary_icon: "fas fa-newspaper",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Articles", value: @features.size, icon: "fas fa-newspaper" %>
    <%= render "dashboards/stat_card",
          label: "With Image",
          value: @features.count { |f| f.image.present? },
          icon: "fas fa-image" %>
    <%= render "dashboards/stat_card",
          label: "Latest",
          value: @features.first&.created_at&.strftime("%b %d") || "—",
          icon: "fas fa-clock" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Featured articles",
        action: link_to("Add Feature", new_feature_path, class: "btn-dash")
      } do %>
    <% if @features.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Cover</th>
              <th>Heading</th>
              <th>Intro</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @features.each do |feature| %>
              <% thumb = (feature.image_url(:thumb) rescue nil) || (feature.image_url rescue nil) %>
              <tr>
                <td>
                  <% if thumb.present? %>
                    <%= image_tag thumb, alt: feature.heading, class: "dash-thumb" %>
                  <% else %>
                    <div class="dash-thumb d-inline-flex align-items-center justify-content-center text-muted">
                      <i class="fas fa-newspaper"></i>
                    </div>
                  <% end %>
                </td>
                <td><strong><%= feature.heading %></strong></td>
                <td class="text-muted"><%= truncate(feature.intro.to_s, length: 80) %></td>
                <td><%= time_ago_in_words(feature.created_at) %> ago</td>
                <td>
                  <%= link_to "View", feature_path(feature), class: "btn-dash btn-sm me-1" %>
                  <%= link_to "Edit", edit_feature_path(feature), class: "btn-dash-outline btn-sm me-1" %>
                  <%= button_to "Delete", feature_path(feature),
                        method: :delete,
                        form: { data: { turbo_confirm: "Delete this feature?" }, class: "d-inline" },
                        class: "btn-dash-danger btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No features yet.</p>
        <%= link_to "Create Your First Feature", new_feature_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
