<% content_for :title, "News — Red Village" %>

<div class="container py-4">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">News</h1>
    <p class="rv-sub">Stories from the Red Village creative community.</p>
    <hr class="rv-rule">
  </div>

  <% if @features.present? %>
    <div class="row g-4">
      <% @features.each do |feature| %>
        <div class="col-md-6">
          <article class="card rv-card h-100">
            <div class="row g-0 h-100">
              <div class="col-sm-5">
                <% img = feature.image_url rescue nil %>
                <% if img.present? %>
                  <%= image_tag img, alt: feature.heading, class: "w-100 h-100", style: "object-fit:cover;min-height:160px;" %>
                <% else %>
                  <div class="rv-thumb-placeholder h-100" style="border-radius:0;min-height:160px;"><i class="fas fa-newspaper fa-2x"></i></div>
                <% end %>
              </div>
              <div class="col-sm-7">
                <div class="card-body d-flex flex-column h-100">
                  <time class="small text-muted mb-1"><%= feature.created_at.strftime("%d %b %Y") %></time>
                  <h2 class="h5 card-title"><%= feature.heading %></h2>
                  <% if feature.intro.present? %>
                    <p class="card-text text-muted small flex-grow-1"><%= truncate(feature.intro, length: 140) %></p>
                  <% end %>
                  <% if feature.link.present? %>
                    <%= link_to "Read more", feature.link, class: "btn btn-rv btn-rv-sm align-self-start mt-2", target: "_blank", rel: "noopener" %>
                  <% elsif feature.persisted? %>
                    <%= link_to "Read more", feature_path(feature), class: "btn btn-rv btn-rv-sm align-self-start mt-2" %>
                  <% end %>
                </div>
              </div>
            </div>
          </article>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted py-5 mb-0">No news yet. Check back soon.</p>
  <% end %>
</div>
