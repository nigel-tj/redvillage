<% content_for :title, "#{@feature.heading} — Red Village" %>

<div class="container py-4">
  <div class="rv-section-head text-start">
    <p class="small text-muted mb-2"><%= @feature.created_at.strftime("%d %B %Y") %></p>
    <h1 class="rv-gradient-text"><%= @feature.heading %></h1>
    <hr class="rv-rule rv-rule-start">
  </div>

  <div class="row g-4">
    <div class="col-lg-8">
      <% img = @feature.image_url rescue nil %>
      <% if img.present? %>
        <%= image_tag img, alt: @feature.heading, class: "img-fluid rounded-4 mb-4 w-100", style: "max-height:420px;object-fit:cover;" %>
      <% end %>
      <% if @feature.intro.present? %>
        <div class="lead text-muted mb-4"><%= simple_format(@feature.intro) %></div>
      <% end %>
      <% if @feature.link.present? %>
        <%= link_to "Read the full story", @feature.link, class: "btn btn-rv", target: "_blank", rel: "noopener" %>
      <% end %>
    </div>
    <div class="col-lg-4">
      <%= link_to "Back to news", "/news", class: "btn btn-outline-rv w-100" %>
    </div>
  </div>
</div>
