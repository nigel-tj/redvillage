<div class="dash">
  <%= render "shared/dash_page_header",
        title: "New Feature",
        eyebrow: "Editorial",
        subtitle: "Publish a news feature for the homepage and news section.",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Article details", padded: true } do %>
    <%= form_for @feature, html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @feature %>

      <div class="mb-3">
        <%= f.label :heading, class: "form-label" %>
        <%= f.text_field :heading, class: "form-control", required: true, id: "word_count", placeholder: "Article heading" %>
        <div class="form-text mt-1">
          Words: <span id="display_count">0</span> · Left: <span id="word_left">20</span> (max 20)
        </div>
      </div>

      <div class="mb-3">
        <%= render "shared/dash_upload",
              form: f,
              method: :image,
              label: "Feature image",
              hint: "JPG or PNG hero image",
              required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :intro, class: "form-label" %>
        <%= f.text_area :intro, class: "form-control", required: true, rows: 4, placeholder: "Short introduction" %>
      </div>

      <div class="mb-3">
        <%= f.label :link, "Article URL", class: "form-label" %>
        <%= f.text_field :link, class: "form-control", required: true, placeholder: "https://" %>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: "/admin_index",
            submit_label: "Create Feature" %>
    <% end %>
  <% end %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var input = document.getElementById("word_count");
    if (!input) return;
    input.addEventListener("keyup", function () {
      var words = (this.value.match(/\S+/g) || []).length;
      if (words > 20) {
        this.value = this.value.split(/\s+/).slice(0, 20).join(" ") + " ";
        words = 20;
      }
      document.getElementById("display_count").textContent = words;
      document.getElementById("word_left").textContent = 20 - words;
    });
  });
</script>
