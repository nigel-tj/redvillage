<div class="dash">
  <%= render "shared/dash_page_header",
        title: "Users",
        eyebrow: "Platform admin",
        subtitle: params[:role].present? ? "Filtered by #{params[:role].to_s.titleize}." : "Manage roles and access across Red Village.",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Shown", value: @users.size, icon: "fas fa-users" %>
    <%= render "dashboards/stat_card",
          label: "Filter",
          value: params[:role].present? ? params[:role].to_s.titleize : "All roles",
          icon: "fas fa-filter" %>
    <%= render "dashboards/stat_card",
          label: "Admins",
          value: @users.count { |u| u.role.to_s == "admin" },
          icon: "fas fa-user-shield" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Directory",
        action: link_to("All users", users_path, class: "btn-dash-outline btn-sm")
      } do %>
    <% if @users.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Email</th>
              <th>Role</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td>
                  <strong><%= link_to user.email, user_path(user), class: "text-decoration-none" %></strong>
                  <% if user.name.present? %>
                    <div class="text-muted small"><%= user.name %></div>
                  <% end %>
                </td>
                <td>
                  <%= form_for(user, html: { class: "d-flex flex-wrap gap-2 align-items-center" }) do |f| %>
                    <%= f.select :role,
                          User.roles.keys.map { |role| [role.titleize, role] },
                          {},
                          { class: "form-select form-select-sm", style: "min-width: 10rem;" } %>
                    <%= f.submit "Change Role", class: "btn-dash btn-sm" %>
                  <% end %>
                </td>
                <td>
                  <% unless user == current_user %>
                    <%= link_to "Delete", user_path(user),
                          data: { turbo_method: :delete, turbo_confirm: "Delete this user?" },
                          class: "btn-dash-danger btn-sm" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No users match this filter.</p>
      </div>
    <% end %>
  <% end %>
</div>
