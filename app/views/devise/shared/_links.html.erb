<% if controller_name != "sessions" %>
  <p class="mb-2">
    Already have an account?
    <%= link_to "Sign in", new_session_path(resource_name), class: "rv-auth__link" %>
  </p>
<% end %>

<% if devise_mapping.registerable? && controller_name != "registrations" %>
  <p class="mb-2">
    New here?
    <%= link_to "Create an account", new_registration_path(resource_name), class: "rv-auth__link" %>
  </p>
<% end %>

<% if devise_mapping.recoverable? && !%w[passwords registrations sessions].include?(controller_name) %>
  <p class="mb-0">
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "rv-auth__link" %>
  </p>
<% end %>
