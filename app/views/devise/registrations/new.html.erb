<% content_for :title, "Join | Red Village" %>

<section class="rv-auth rv-reveal">
  <div class="container">
    <div class="rv-auth__panel">
      <header class="rv-auth__brand">
        <p class="rv-auth__brand-name">RED VILLAGE</p>
        <hr class="rv-rule">
        <h1 class="rv-auth__title">Create your account</h1>
        <p class="rv-auth__lede">Join the creative marketplace</p>
      </header>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "rv-auth__form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.label :name, "Full name", class: "form-label" %>
          <%= f.text_field :name,
                autofocus: true,
                autocomplete: "name",
                class: "form-control form-control-lg",
                placeholder: "Your name",
                required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email,
                autocomplete: "email",
                class: "form-control form-control-lg",
                placeholder: "you@example.com",
                required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :password, class: "form-label" %>
          <%= f.password_field :password,
                autocomplete: "new-password",
                class: "form-control form-control-lg",
                placeholder: "At least #{@minimum_password_length || 8} characters",
                required: true,
                minlength: (@minimum_password_length || 8) %>
          <% if @minimum_password_length %>
            <small class="form-text text-muted"><%= @minimum_password_length %> characters minimum</small>
          <% end %>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, "Confirm password", class: "form-label" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "form-control form-control-lg",
                placeholder: "Confirm your password",
                required: true %>
        </div>

        <%= f.submit "Create account", class: "btn btn-rv w-100" %>
      <% end %>

      <footer class="rv-auth__footer">
        <%= render "devise/shared/links" %>
      </footer>
    </div>
  </div>
</section>
