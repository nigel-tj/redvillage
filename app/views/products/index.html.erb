<% manage = user_signed_in? && (@store.owner?(current_user) || current_user&.admin?) %>

<% if manage %>
  <div class="dash">
    <%= render "dashboards/header",
          title: "Products",
          eyebrow: @store.name,
          subtitle: truncate(@store.description.to_s, length: 100),
          primary_path: new_store_product_path(@store),
          primary_label: "Add Product",
          primary_icon: "fas fa-plus",
          user: current_user %>

    <%= render layout: "dashboards/panel", locals: { title: "Catalog", padded: true } do %>
      <%= form_with url: store_products_path(@store), method: :get, local: true, class: "dash-form mb-3" do |f| %>
        <div class="d-flex flex-wrap gap-2">
          <%= f.text_field :search, placeholder: "Search products…", value: params[:search], class: "form-control", style: "max-width: 280px;" %>
          <%= f.submit "Search", class: "btn-dash-outline" %>
        </div>
      <% end %>

      <% if @products.any? %>
        <div class="dash-card-grid">
          <% @products.each do |product| %>
            <article class="dash-media-card">
              <div class="dash-media-card__thumb">
                <% if product.primary_image %>
                  <%= link_to store_product_path(@store, product) do %>
                    <%= image_tag product.primary_image.image_url(:medium) || product.primary_image.image, alt: product.name %>
                  <% end %>
                <% else %>
                  <i class="fas fa-image"></i>
                <% end %>
              </div>
              <div class="dash-media-card__body">
                <h3 class="dash-media-card__title">
                  <%= link_to product.name, store_product_path(@store, product) %>
                </h3>
                <p class="dash-media-card__meta"><%= truncate(product.description.to_s, length: 70) %></p>
                <div class="mt-1">
                  <strong><%= product.formatted_price %></strong>
                  <% if product.in_stock? %>
                    <span class="dash-badge dash-badge--ok ms-1">In stock</span>
                  <% else %>
                    <span class="dash-badge dash-badge--danger ms-1">Out of stock</span>
                  <% end %>
                  <% if product.featured? %>
                    <span class="dash-badge ms-1">Featured</span>
                  <% end %>
                </div>
                <div class="dash-media-card__actions">
                  <%= link_to "View", store_product_path(@store, product), class: "btn-dash btn-sm" %>
                  <%= link_to "Edit", edit_store_product_path(@store, product), class: "btn-dash-outline btn-sm" %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
        <%= paginate @products if @products.respond_to?(:current_page) %>
      <% else %>
        <div class="dash-empty">
          <i class="fas fa-box-open d-block"></i>
          <h3>No products found</h3>
          <%= link_to "Add Product", new_store_product_path(@store), class: "btn-dash" %>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="container mt-4">
    <div class="storefront-header mb-4" style="<%= "background-color: #{@store.storefront_settings_with_defaults.primary_color}; color: white; padding: 2rem; border-radius: 0.5rem;" if @store.storefront_settings.present? %>">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1><%= @store.name %></h1>
          <p class="mb-0"><%= @store.description %></p>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <div class="row align-items-center">
        <div class="col-md-6"><h2>Products</h2></div>
        <div class="col-md-6">
          <%= form_with url: store_products_path(@store), method: :get, local: true, class: "d-flex gap-2" do |f| %>
            <%= f.text_field :search, placeholder: "Search products...", value: params[:search], class: "form-control" %>
            <%= f.submit "Search", class: "btn btn-outline-primary" %>
          <% end %>
        </div>
      </div>
    </div>

    <% if @products.any? %>
      <div class="row">
        <% @products.each do |product| %>
          <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
              <% if product.primary_image %>
                <%= link_to store_product_path(@store, product) do %>
                  <div style="height: 200px; overflow: hidden; background: #f8f9fa;">
                    <%= image_tag product.primary_image.image_url(:medium) || product.primary_image.image, alt: product.name, style: "width: 100%; height: 100%; object-fit: cover;" %>
                  </div>
                <% end %>
              <% else %>
                <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                  <i class="fas fa-image fa-3x text-white"></i>
                </div>
              <% end %>
              <div class="card-body d-flex flex-column">
                <h5 class="card-title"><%= link_to product.name, store_product_path(@store, product), class: "text-decoration-none" %></h5>
                <p class="card-text text-muted flex-grow-1"><%= truncate(product.description, length: 80) %></p>
                <div class="mb-2">
                  <span class="h5 text-primary"><%= product.formatted_price %></span>
                  <% if product.has_discount? %>
                    <span class="badge bg-danger ms-2">-<%= product.discount_percentage %>%</span>
                  <% end %>
                </div>
                <div class="mt-auto">
                  <% if product.in_stock? %>
                    <%= form_with url: add_item_store_cart_path(@store), method: :post, local: true do |f| %>
                      <%= f.hidden_field :product_id, value: product.id %>
                      <%= f.hidden_field :quantity, value: 1 %>
                      <%= f.submit "Add to Cart", class: "btn btn-primary w-100" %>
                    <% end %>
                  <% else %>
                    <button class="btn btn-secondary w-100" disabled>Out of Stock</button>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="mt-4"><%= paginate @products %></div>
    <% else %>
      <div class="text-center py-5">
        <h3>No products found</h3>
        <p class="text-muted">This store doesn't have any products yet.</p>
      </div>
    <% end %>
  </div>
<% end %>
