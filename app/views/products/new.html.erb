<div class="dash">
  <%= render "dashboards/header",
        title: "Add Product",
        eyebrow: @store.name,
        subtitle: "Create a product for this storefront.",
        primary_path: store_products_path(@store),
        primary_label: "All Products",
        primary_icon: "fas fa-box",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Product details", padded: true } do %>
    <%= form_for [@store, @product], html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @product %>

      <div class="row g-3">
        <div class="col-md-8">
          <%= f.label :name, "Product name", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", required: true, placeholder: "Product name" %>
        </div>
        <div class="col-md-4">
          <%= f.label :sku, "SKU", class: "form-label" %>
          <%= f.text_field :sku, class: "form-control", placeholder: "Optional" %>
        </div>
        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Product description" %>
        </div>
        <div class="col-md-4">
          <%= f.label :price, "Price", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :price, class: "form-control", step: 0.01, min: 0, required: true, placeholder: "0.00" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :compare_at_price, "Compare at", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :compare_at_price, class: "form-control", step: 0.01, min: 0, placeholder: "0.00" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :inventory_quantity, "Inventory", class: "form-label" %>
          <%= f.number_field :inventory_quantity, class: "form-control", min: 0, value: 0, required: true %>
        </div>
        <div class="col-md-6">
          <%= f.label :weight, "Weight (lbs)", class: "form-label" %>
          <%= f.number_field :weight, class: "form-control", step: 0.01, min: 0, placeholder: "Optional" %>
        </div>
        <div class="col-md-6">
          <%= f.label :status, "Status", class: "form-label" %>
          <%= f.select :status, options_for_select([["Active", "active"], ["Inactive", "inactive"]], @product.status), {}, { class: "form-select" } %>
        </div>
        <div class="col-12">
          <div class="form-check">
            <%= f.check_box :featured, class: "form-check-input" %>
            <%= f.label :featured, "Feature this product", class: "form-check-label" %>
          </div>
          <small class="form-text">You can add images after creating the product.</small>
        </div>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: store_products_path(@store),
            submit_label: "Create Product" %>
    <% end %>
  <% end %>
</div>
