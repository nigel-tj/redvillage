<div class="dash">
  <%= render "dashboards/header",
        title: "Edit Product",
        eyebrow: @store.name,
        subtitle: @product.name,
        primary_path: store_product_path(@store, @product),
        primary_label: "View Product",
        primary_icon: "fas fa-eye",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Product details", padded: true } do %>
    <%= form_for [@store, @product], html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @product %>

      <div class="row g-3">
        <div class="col-md-8">
          <%= f.label :name, "Product name", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", required: true, placeholder: "Product name" %>
        </div>
        <div class="col-md-4">
          <%= f.label :sku, "SKU", class: "form-label" %>
          <%= f.text_field :sku, class: "form-control", placeholder: "Optional" %>
        </div>
        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Product description" %>
        </div>
        <div class="col-md-4">
          <%= f.label :price, "Price", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :price, class: "form-control", step: 0.01, min: 0, required: true, placeholder: "0.00" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :compare_at_price, "Compare at", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :compare_at_price, class: "form-control", step: 0.01, min: 0, placeholder: "0.00" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :inventory_quantity, "Inventory", class: "form-label" %>
          <%= f.number_field :inventory_quantity, class: "form-control", min: 0, required: true %>
        </div>
        <div class="col-md-6">
          <%= f.label :weight, "Weight (lbs)", class: "form-label" %>
          <%= f.number_field :weight, class: "form-control", step: 0.01, min: 0, placeholder: "Optional" %>
        </div>
        <div class="col-md-6">
          <%= f.label :status, "Status", class: "form-label" %>
          <%= f.select :status,
                options_for_select([["Active", "active"], ["Inactive", "inactive"], ["Out of Stock", "out_of_stock"]], @product.status),
                {},
                { class: "form-select" } %>
        </div>
        <div class="col-12">
          <div class="form-check">
            <%= f.check_box :featured, class: "form-check-input" %>
            <%= f.label :featured, "Feature this product", class: "form-check-label" %>
          </div>
        </div>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: store_product_path(@store, @product),
            submit_label: "Update Product" %>
    <% end %>
  <% end %>

  <%= render layout: "dashboards/panel", locals: { title: "Product images", padded: true } do %>
    <% if @product.product_images.any? %>
      <div class="dash-card-grid dash-card-grid--dense mb-3">
        <% @product.product_images.ordered.each do |img| %>
          <article class="dash-media-card">
            <div class="dash-media-card__thumb">
              <%= image_tag img.image_url(:thumbnail) || img.image, alt: img.alt_text.presence || @product.name %>
            </div>
            <div class="dash-media-card__body">
              <p class="dash-media-card__meta mb-2">Position <%= img.position %></p>
              <div class="dash-media-card__actions">
                <%= link_to "Remove",
                      store_product_product_image_path(@store, @product, img),
                      method: :delete,
                      data: { confirm: "Remove this image?" },
                      class: "btn-dash-danger btn-sm" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="dash-empty mb-3">
        <p class="mb-0">No images yet.</p>
      </div>
    <% end %>

    <%= form_with url: store_product_product_images_path(@store, @product), method: :post, local: true, html: { multipart: true, class: "dash-form" } do |f| %>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Add image</label>
          <label class="dash-upload">
            <span class="dash-upload__icon"><i class="fas fa-image"></i></span>
            <span class="dash-upload__text">
              <strong>Drop image or click to browse</strong>
              <span class="dash-upload__hint">JPG or PNG</span>
            </span>
            <%= f.file_field :image, class: "dash-upload__input", accept: "image/*", name: "product_image[image]" %>
          </label>
        </div>
        <div class="col-md-6">
          <%= f.label :alt_text, "Alt text", class: "form-label" %>
          <%= f.text_field :alt_text, class: "form-control", placeholder: "Image description", name: "product_image[alt_text]" %>
        </div>
      </div>
      <div class="dash-form__actions">
        <span></span>
        <%= f.submit "Add Image", class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
