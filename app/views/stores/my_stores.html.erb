<div class="dash">
  <% can_create_store = current_user.can_create_store? %>
  <%= render "dashboards/header",
        title: "My Stores",
        eyebrow: "Marketplace",
        subtitle: "Manage your storefronts, products, and orders.",
        primary_path: (can_create_store ? new_store_path : nil),
        primary_label: (can_create_store ? "Create Store" : nil),
        primary_icon: "fas fa-plus",
        user: current_user %>

  <% all_stores = current_user.stores %>
  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Stores", value: all_stores.count, icon: "fas fa-store" %>
    <%= render "dashboards/stat_card", label: "Active", value: all_stores.where(active: true).count, icon: "fas fa-check-circle" %>
    <%= render "dashboards/stat_card", label: "In a mall", value: all_stores.where.not(mall_id: nil).count, icon: "fas fa-building" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Your storefronts",
        action: (can_create_store ? link_to("Create Store", new_store_path, class: "btn-dash") : nil)
      } do %>
    <% if @stores.any? %>
      <div class="dash-card-grid" style="padding: 1rem 1.15rem 1.15rem;">
        <% @stores.each do |store| %>
          <% cover_url = nil
             if store.cover.present? && store.cover.to_s.strip.present?
               cover_url = store.cover.to_s.strip
               cover_url = "/#{cover_url}" unless cover_url.start_with?("http://", "https://", "/")
             end %>
          <article class="dash-media-card">
            <div class="dash-media-card__thumb">
              <% if cover_url.present? %>
                <%= link_to store_path(store) do %>
                  <%= image_tag cover_url, alt: store.name %>
                <% end %>
              <% else %>
                <i class="fas fa-store"></i>
              <% end %>
            </div>
            <div class="dash-media-card__body">
              <h3 class="dash-media-card__title">
                <%= link_to store.name, store_path(store) %>
              </h3>
              <p class="dash-media-card__meta"><%= truncate(store.description.to_s, length: 90) %></p>
              <div class="mt-2">
                <% if store.active? %>
                  <span class="dash-badge dash-badge--ok">Active</span>
                <% else %>
                  <span class="dash-badge dash-badge--warn">Inactive</span>
                <% end %>
                <% if store.mall.present? %>
                  <span class="dash-badge dash-badge--muted"><%= store.mall.name %></span>
                <% end %>
              </div>
              <div class="dash-media-card__actions">
                <%= link_to "Dashboard", store_dashboard_path(store), class: "btn-dash btn-sm" %>
                <%= link_to "Edit", edit_store_path(store), class: "btn-dash-outline btn-sm" %>
                <%= link_to "Products", store_products_path(store), class: "btn-dash-outline btn-sm" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
      <div class="px-3 pb-3"><%= paginate @stores if @stores.respond_to?(:current_page) %></div>
    <% else %>
      <div class="dash-empty padded">
        <i class="fas fa-store d-block"></i>
        <h3>No stores yet</h3>
        <p>Create your first storefront to start selling.</p>
        <% if can_create_store %>
          <%= link_to "Create Store", new_store_path, class: "btn-dash" %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
