<div class="container mt-4">
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <h1>
          <i class="fas fa-store me-2"></i>
          Stores
        </h1>
        <% if user_signed_in? %>
          <%= link_to new_store_path, class: 'btn btn-primary' do %>
            <i class="fas fa-plus me-1"></i> Create Store
          <% end %>
        <% end %>
      </div>
      <% if user_signed_in? %>
        <p class="text-muted">
          <%= link_to my_stores_path, class: 'text-decoration-none' do %>
            <i class="fas fa-user me-1"></i> View My Stores
          <% end %>
        </p>
      <% end %>
    </div>
  </div>

  <% if @stores.any? %>
    <div class="row">
      <% @stores.each do |store| %>
        <div class="col-xl-4 col-lg-4 col-md-6 mb-4">
          <div class="card h-100 shadow-sm">
            <% if store.cover.present? && store.cover.to_s.strip.present? %>
              <%= link_to store_path(store) do %>
                <div style="height: 200px; overflow: hidden; background: #f8f9fa;">
                  <% cover_url = store.cover.to_s.strip %>
                  <% cover_url = "/#{cover_url}" unless cover_url.start_with?('http://', 'https://') || cover_url.start_with?('/') %>
                  <%= image_tag cover_url, alt: store.name, style: "width: 100%; height: 100%; object-fit: cover;" %>
                </div>
              <% end %>
            <% else %>
              <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                <i class="fas fa-store fa-4x text-white"></i>
              </div>
            <% end %>
            
            <div class="card-body">
              <h5 class="card-title">
                <%= link_to store.name, store_path(store), class: "text-decoration-none" %>
              </h5>
              <p class="card-text text-muted">
                <%= truncate(store.description, length: 100) %>
              </p>
              
              <div class="mb-2">
                <small class="text-muted">
                  <i class="fas fa-user me-1"></i>
                  <%= store.user.name %>
                </small>
              </div>
              
              <% if store.mall.present? %>
                <div class="mb-2">
                  <small class="text-muted">
                    <i class="fas fa-building me-1"></i>
                    <%= link_to store.mall.name, mall_path(store.mall), class: "text-decoration-none" %>
                  </small>
                </div>
              <% end %>
              
              <% unless store.active? %>
                <span class="badge bg-warning text-dark">Inactive</span>
              <% end %>
            </div>
            
            <div class="card-footer bg-white">
              <%= link_to "View Store", store_path(store), class: "btn btn-sm btn-primary w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    
    <div class="row mt-4">
      <div class="col-12">
        <%= paginate @stores %>
      </div>
    </div>
  <% else %>
    <div class="row">
      <div class="col-12">
        <div class="empty-state text-center py-5">
          <i class="fas fa-store fa-4x mb-3 text-muted"></i>
          <h3>No stores found</h3>
          <p class="mb-4 text-muted">
            <% if user_signed_in? %>
              <%= link_to "Create the first store", new_store_path, class: "btn btn-primary" %>
            <% else %>
              <%= link_to "Sign up", new_user_registration_path, class: "btn btn-primary" %> to create a store
            <% end %>
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>
