<% content_for :title, "Stores — Red Village" %>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div class="rv-section-head text-start mb-0">
      <h1 class="rv-gradient-text">Stores</h1>
      <p class="rv-sub mb-0">Maker storefronts inside the Red Village marketplace.</p>
      <hr class="rv-rule rv-rule-start">
    </div>
    <div class="d-flex flex-wrap gap-2">
      <% if user_signed_in? %>
        <%= link_to "My stores", my_stores_path, class: "btn btn-outline-rv btn-rv-sm" %>
        <%= link_to "Create store", new_store_path, class: "btn btn-rv btn-rv-sm" %>
      <% end %>
    </div>
  </div>

  <% if @stores.any? %>
    <div class="row g-4">
      <% @stores.each do |store| %>
        <div class="col-md-6 col-lg-4">
          <div class="card rv-card h-100">
            <% if store.cover.present? && store.cover.to_s.strip.present? %>
              <%= link_to store_path(store) do %>
                <% cover_url = store.cover.to_s.strip %>
                <% cover_url = "/#{cover_url}" unless cover_url.start_with?('http://', 'https://', '/') %>
                <%= image_tag cover_url, alt: store.name, class: "rv-img" %>
              <% end %>
            <% else %>
              <div class="rv-thumb-placeholder"><i class="fas fa-store fa-2x"></i></div>
            <% end %>
            <div class="card-body">
              <h2 class="h5 card-title">
                <%= link_to store.name, store_path(store), class: "text-decoration-none" %>
              </h2>
              <p class="card-text text-muted small"><%= truncate(store.description.to_s, length: 100) %></p>
              <% if store.user.present? %>
                <p class="small text-muted mb-1"><i class="fas fa-user me-1"></i><%= store.user.name %></p>
              <% end %>
              <% if store.mall.present? %>
                <p class="small text-muted mb-0">
                  <i class="fas fa-building me-1"></i>
                  <%= link_to store.mall.name, mall_path(store.mall), class: "text-decoration-none" %>
                </p>
              <% end %>
              <% unless store.active? %>
                <span class="badge mt-2" style="background:rgba(255,201,87,0.2);color:#ffc857;">Inactive</span>
              <% end %>
            </div>
            <div class="card-footer border-0 bg-transparent pt-0">
              <%= link_to "View store", store_path(store), class: "btn btn-rv btn-rv-sm w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-4"><%= paginate @stores if @stores.respond_to?(:current_page) %></div>
  <% else %>
    <div class="text-center py-5">
      <p class="text-muted mb-3">No stores yet.</p>
      <% if user_signed_in? %>
        <%= link_to "Create the first store", new_store_path, class: "btn btn-rv" %>
      <% else %>
        <%= link_to "Join to open a store", new_user_registration_path, class: "btn btn-rv" %>
      <% end %>
    </div>
  <% end %>
</div>
