<% cover_url = nil
   if @store.cover.present? && @store.cover.to_s.strip.present?
     cover_url = @store.cover.to_s.strip
     cover_url = "/#{cover_url}" unless cover_url.start_with?("http://", "https://", "/")
   end %>

<div class="dash">
  <%= render "dashboards/header",
        title: "Edit Store",
        eyebrow: "Marketplace",
        subtitle: "Update details for #{@store.name}.",
        primary_path: store_path(@store),
        primary_label: "View Store",
        primary_icon: "fas fa-eye",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Store details", padded: true } do %>
    <%= form_for @store, html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @store %>

      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :name, "Store name", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", required: true, placeholder: "Store name" %>
        </div>
        <div class="col-md-6">
          <%= f.label :email, "Store email", class: "form-label" %>
          <%= f.email_field :email, class: "form-control", required: true, placeholder: "store@example.com" %>
        </div>
        <div class="col-md-6">
          <%= f.label :contact_number, "Contact number", class: "form-label" %>
          <%= f.text_field :contact_number, class: "form-control", placeholder: "Optional phone" %>
        </div>
        <div class="col-md-6">
          <%= f.label :mall_id, "Mall (optional)", class: "form-label" %>
          <%= f.select :mall_id,
                options_from_collection_for_select(@malls, :id, :name, @store.mall_id),
                { prompt: "Standalone store" },
                { class: "form-select" } %>
        </div>
        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, class: "form-control", required: true, rows: 4,
                placeholder: "What you sell and what makes the store special" %>
        </div>
        <div class="col-12">
          <%= render "shared/dash_upload",
                form: f,
                method: :cover,
                label: "Cover image",
                text: "Replace cover image",
                hint: "JPG or PNG · leave empty to keep current",
                icon: "fas fa-image",
                current_url: cover_url %>
        </div>
        <% if current_user&.admin? %>
          <div class="col-12">
            <div class="form-check">
              <%= f.check_box :active, class: "form-check-input" %>
              <%= f.label :active, "Active — visible to the public", class: "form-check-label" %>
            </div>
          </div>
        <% end %>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: store_path(@store),
            submit_label: "Update Store" %>
    <% end %>
  <% end %>
</div>
