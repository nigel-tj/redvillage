<% content_for :title, "#{@store.name} — Red Village" %>

<div class="container py-4">
  <div class="card rv-card mb-4 overflow-hidden">
    <% if @store.cover.present? && @store.cover.to_s.strip.present? %>
      <% cover_url = @store.cover.to_s.strip %>
      <% cover_url = "/#{cover_url}" unless cover_url.start_with?('http://', 'https://', '/') %>
      <%= image_tag cover_url, alt: @store.name, class: "w-100", style: "max-height:360px;object-fit:cover;" %>
    <% else %>
      <div class="rv-thumb-placeholder" style="height:220px;border-radius:0;"><i class="fas fa-store fa-3x"></i></div>
    <% end %>
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
          <h1 class="h2 mb-2"><%= @store.name %></h1>
          <% unless @store.active? %>
            <span class="badge mb-2" style="background:rgba(255,201,87,0.2);color:#ffc857;">Inactive</span>
          <% end %>
          <% if @store.description.present? %>
            <div class="text-muted"><%= simple_format(@store.description) %></div>
          <% end %>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <%= link_to "All stores", stores_path, class: "btn btn-outline-rv btn-rv-sm" %>
          <% if @store.mall.present? %>
            <%= link_to @store.mall.name, mall_path(@store.mall), class: "btn btn-outline-rv btn-rv-sm" %>
          <% end %>
        </div>
      </div>

      <div class="row g-3 mt-2">
        <% if @store.email.present? %>
          <div class="col-md-6"><span class="small text-muted">Email</span><div><%= mail_to @store.email %></div></div>
        <% end %>
        <% if @store.contact_number.present? %>
          <div class="col-md-6"><span class="small text-muted">Phone</span><div><%= link_to @store.contact_number, "tel:#{@store.contact_number}" %></div></div>
        <% end %>
        <% if @store.user.present? %>
          <div class="col-md-6"><span class="small text-muted">Owner</span><div><%= @store.user.name %></div></div>
        <% end %>
      </div>
    </div>
  </div>

  <% products = @store.respond_to?(:products) ? @store.products.to_a : [] %>
  <% if products.any? %>
    <div class="rv-section-head">
      <h2 class="rv-gradient-text h3">Products</h2>
      <hr class="rv-rule">
    </div>
    <div class="row g-4">
      <% products.each do |product| %>
        <div class="col-sm-6 col-lg-4">
          <div class="card rv-card h-100">
            <div class="card-body">
              <h3 class="h6 card-title"><%= link_to product.name, store_product_path(@store, product), class: "text-decoration-none" rescue product.name %></h3>
              <% if product.respond_to?(:price) && product.price.present? %>
                <p class="mb-0" style="color:#ff8fbf;"><%= number_to_currency(product.price) rescue product.price %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
