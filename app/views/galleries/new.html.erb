<div class="dash">
  <%= render "shared/dash_page_header",
        title: "New Gallery",
        eyebrow: "Visual archive",
        subtitle: "Create a gallery, then add images from the gallery workspace.",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Gallery details", padded: true } do %>
    <%= form_for @gallery, html: { multipart: true, class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @gallery %>

      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", required: true, placeholder: "e.g. Street Style Week" %>
      </div>

      <div class="mb-3">
        <%= f.label :category, class: "form-label" %>
        <%= f.text_field :category, class: "form-control", placeholder: "e.g. Painting, Fashion" %>
      </div>

      <div class="mb-3">
        <%= render "shared/dash_upload",
              form: f,
              method: :image,
              label: "Cover image",
              hint: "JPG or PNG cover for this gallery",
              required: true %>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: dashboard_path_for_user(current_user),
            submit_label: "Create Gallery" %>
    <% end %>
  <% end %>
</div>
