<% content_for :title, "#{@gallery.name} — Red Village" %>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div class="rv-section-head text-start mb-0">
      <h1 class="rv-gradient-text h2 mb-1"><%= @gallery.name.presence || "Gallery" %></h1>
      <hr class="rv-rule rv-rule-start">
    </div>
    <div class="d-flex flex-wrap gap-2">
      <% if user_signed_in? && (current_user.admin? || current_user.photographer?) %>
        <%= link_to "Add images", new_image_path(gallery_id: @gallery.id), class: "btn btn-rv btn-rv-sm" %>
      <% end %>
      <%= link_to "Back", galleries_path, class: "btn btn-outline-rv btn-rv-sm" %>
    </div>
  </div>

  <% images = @gallery.images.to_a %>
  <% if images.any? %>
    <div class="row g-3">
      <% images.each do |image| %>
        <div class="col-6 col-md-4">
          <% url = image.image_url(:original) rescue image.image_url %>
          <% thumb = (image.image_url(:thumbnail) rescue nil) || (image.image_url(:thumb) rescue nil) || url %>
          <% if thumb.present? %>
            <a href="<%= url %>" target="_blank" rel="noopener">
              <%= image_tag thumb, alt: image.name.to_s, class: "img-fluid rounded-3 w-100", style: "height:220px;object-fit:cover;" %>
            </a>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted py-5 mb-0">No images yet.</p>
  <% end %>
</div>
