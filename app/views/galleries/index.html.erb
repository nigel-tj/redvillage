<% content_for :title, "Galleries — Red Village" %>

<div class="container py-4">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">Galleries</h1>
    <p class="rv-sub">Photography collections from the Red Village community.</p>
    <hr class="rv-rule">
  </div>

  <% if @galleries.present? %>
    <div class="row g-4">
      <% @galleries.each do |gallery| %>
        <div class="col-sm-6 col-lg-4">
          <%= link_to show_gallery_path(gallery), class: "rv-event-tile text-decoration-none" do %>
            <div class="rv-event-tile__media">
              <% cover = gallery.image_url.presence || gallery.images.first&.image_url %>
              <% if cover.present? %>
                <%= image_tag cover, alt: gallery.name, class: "rv-event-tile__img" %>
              <% else %>
                <div class="rv-event-tile__placeholder" aria-hidden="true"></div>
              <% end %>
            </div>
            <div class="rv-event-tile__body">
              <h2 class="rv-event-tile__title h5"><%= gallery.name.presence || "Gallery" %></h2>
              <% if gallery.category.present? %>
                <p class="text-muted small mb-0 mt-1"><%= gallery.category %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted py-5 mb-0">No galleries yet. Check back soon.</p>
  <% end %>
</div>
