<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css',
        integrity: 'sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH',
        crossorigin: 'anonymous' %>
  <%= stylesheet_link_tag 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css',
        integrity: 'sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==',
        crossorigin: 'anonymous', referrerpolicy: 'no-referrer' %>
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>

  <title><%= content_for?(:title) ? yield(:title) : "Red Village" %></title>
</head>
<body class="marketplace-body<%= ' rv-home' if content_for?(:full_bleed) %>">
  <nav class="navbar navbar-expand-lg marketplace-nav sticky-top">
    <div class="container">
      <a class="navbar-brand" href="/">RED VILLAGE</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#marketplaceNav"
              aria-controls="marketplaceNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon" style="filter:invert(1);"></span>
      </button>
      <div class="collapse navbar-collapse" id="marketplaceNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><%= link_to "Home", "/", class: "nav-link #{'active' if current_page?('/')}" %></li>
          <li class="nav-item"><%= link_to "Events", events_path, class: "nav-link #{'active' if controller_name == 'events'}" %></li>
          <li class="nav-item"><%= link_to "Music", "/music", class: "nav-link #{'active' if current_page?('/music')}" %></li>
          <li class="nav-item"><%= link_to "Gallery", "/gallery", class: "nav-link #{'active' if current_page?('/gallery')}" %></li>
          <li class="nav-item"><%= link_to "Stores", stores_path, class: "nav-link #{'active' if controller_name == 'stores'}" %></li>
          <li class="nav-item"><%= link_to "Malls", malls_path, class: "nav-link #{'active' if controller_name == 'malls'}" %></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle #{'active' if controller_name == 'profiles_listings' || current_page?(team_path)}" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Creators</a>
            <ul class="dropdown-menu">
              <li><%= link_to "Top DJs", top_dj_path, class: "dropdown-item" %></li>
              <li><%= link_to "Artists", artists_listing_path, class: "dropdown-item" %></li>
              <li><%= link_to "Photographers", photographers_listing_path, class: "dropdown-item" %></li>
              <li><%= link_to "All Creators", all_creators_listing_path, class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider border-secondary"></li>
              <li><%= link_to "Our Team", team_path, class: "dropdown-item" %></li>
            </ul>
          </li>
          <li class="nav-item"><%= link_to "Contact", contact_us_path, class: "nav-link #{'active' if current_page?(contact_us_path)}" %></li>
        </ul>
        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
          <% if user_signed_in? %>
            <li class="nav-item"><%= link_to "My Stores", my_stores_path, class: "nav-link" %></li>
            <li class="nav-item">
              <%= link_to destroy_user_session_path, method: :delete, class: "nav-link" do %>
                Logout
              <% end %>
            </li>
          <% else %>
            <li class="nav-item"><%= link_to "Login", new_user_session_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Join", new_user_registration_path, class: "btn btn-rv btn-rv-sm ms-lg-2" %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>

  <% flash.each do |name, msg| %>
    <% if msg.is_a?(String) %>
      <div class="alert alert-<%= name == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show m-3" role="alert">
        <%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
  <% end %>

  <main class="<%= content_for?(:full_bleed) ? 'rv-main-bleed' : 'py-4' %>">
    <%= yield %>
  </main>

  <footer class="rv-footer text-light pt-5 pb-4 mt-5">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-5">
          <p class="rv-footer-brand mb-1">RED VILLAGE</p>
          <p class="text-muted small mb-0">A global creative marketplace — for the makers, the musicians, and the fans. Est. creative community.</p>
        </div>
        <div class="col-6 col-md-3">
          <h6 class="fw-bold mb-3">Explore</h6>
          <ul class="list-unstyled small">
            <li class="mb-2"><%= link_to "Events", events_path %></li>
            <li class="mb-2"><%= link_to "Music", "/music" %></li>
            <li class="mb-2"><%= link_to "Gallery", "/gallery" %></li>
            <li class="mb-2"><%= link_to "Stores", stores_path %></li>
            <li class="mb-2"><%= link_to "Malls", malls_path %></li>
          </ul>
        </div>
        <div class="col-6 col-md-2">
          <h6 class="fw-bold mb-3">Creators</h6>
          <ul class="list-unstyled small">
            <li class="mb-2"><%= link_to "Top DJs", top_dj_path %></li>
            <li class="mb-2"><%= link_to "Artists", artists_listing_path %></li>
            <li class="mb-2"><%= link_to "Team", team_path %></li>
          </ul>
        </div>
        <div class="col-12 col-md-2">
          <h6 class="fw-bold mb-3">Company</h6>
          <ul class="list-unstyled small">
            <li class="mb-2"><%= link_to "About", about_us_path %></li>
            <li class="mb-2"><%= link_to "Blog", blog_path %></li>
            <li class="mb-2"><%= link_to "FAQ", faq_path %></li>
            <li class="mb-2"><%= link_to "Schedule", schedule_path %></li>
            <li class="mb-2"><%= link_to "Contact", contact_us_path %></li>
          </ul>
        </div>
      </div>
      <hr class="border-secondary my-4">
      <p class="text-muted small mb-0">&copy; <%= Date.current.year %> Red Village. All rights reserved.</p>
    </div>
  </footer>

  <%= javascript_include_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js',
        integrity: 'sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz',
        crossorigin: 'anonymous', defer: true %>
  <%= javascript_include_tag 'application', 'data-turbo-track': 'reload', defer: true %>
</body>
</html>
