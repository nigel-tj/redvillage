<div class="dash">
  <%= render "shared/dash_page_header",
        title: "All Videos",
        eyebrow: "Video library",
        subtitle: "Manage YouTube video embeds across the platform.",
        primary_path: new_video_path,
        primary_label: "New Video",
        primary_icon: "fas fa-video",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Total Videos", value: @videos.size, icon: "fas fa-film" %>
    <%= render "dashboards/stat_card",
          label: "With Category",
          value: @videos.count { |v| v.category.present? },
          icon: "fas fa-tags" %>
    <%= render "dashboards/stat_card",
          label: "Latest",
          value: @videos.first&.created_at&.strftime("%b %d") || "—",
          icon: "fas fa-clock" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Video catalog",
        action: link_to("New Video", new_video_path, class: "btn-dash")
      } do %>
    <% if @videos.any? %>
      <div class="dash-media-grid">
        <% @videos.each do |video| %>
          <div class="dash-media-card">
            <div class="dash-media-card__thumb">
              <% if video.uid.present? %>
                <%= image_tag "https://img.youtube.com/vi/#{video.uid}/mqdefault.jpg", alt: video.title.to_s %>
              <% else %>
                <i class="fas fa-video"></i>
              <% end %>
            </div>
            <div class="dash-media-card__body">
              <h3 class="dash-media-card__title"><%= video.title.presence || "Untitled video" %></h3>
              <% if video.category.present? %>
                <p class="dash-media-card__meta">
                  <span class="dash-badge"><%= humanize_category(video.category) %></span>
                </p>
              <% end %>
              <div class="dash-media-card__actions">
                <% if video.uid.present? %>
                  <%= link_to "Watch", "https://www.youtube.com/watch?v=#{video.uid}",
                        class: "btn-dash btn-sm", target: "_blank", rel: "noopener" %>
                <% end %>
                <%= link_to "Edit", edit_video_path(video), class: "btn-dash-outline btn-sm" %>
                <%= button_to "Delete", video_path(video),
                      method: :delete,
                      form: { data: { turbo_confirm: "Delete this video?" }, class: "d-inline" },
                      class: "btn-dash-danger btn-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <p>No videos yet.</p>
        <%= link_to "Add Your First Video", new_video_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
