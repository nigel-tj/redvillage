<div class="dash">
  <%= render "shared/dash_page_header",
        title: "Edit Video",
        eyebrow: "Video library",
        subtitle: @video.title.presence || "Update video details",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Video details", padded: true } do %>
    <%= form_for @video, html: { class: "dash-form" } do |f| %>
      <%= render "shared/errors", object: @video %>

      <div class="mb-3">
        <%= f.label :link, "YouTube link", class: "form-label" %>
        <%= f.text_field :link, class: "form-control", required: true, placeholder: "https://www.youtube.com/watch?v=..." %>
        <small class="form-text text-muted">Paste a full YouTube watch URL</small>
      </div>

      <div class="mb-3">
        <%= f.label :category, class: "form-label" %>
        <%= f.text_field :category, class: "form-control", placeholder: "e.g. Live Session, Interview" %>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: all_videos_path,
            submit_label: "Update Video" %>
    <% end %>
  <% end %>
</div>
