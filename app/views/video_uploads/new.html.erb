<div class="dash">
  <%= render "shared/dash_page_header",
        title: "Upload Video",
        eyebrow: "Video library",
        subtitle: "Upload a video file for processing and publishing.",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Upload details", padded: true } do %>
    <% if current_user || current_admin %>
      <%= form_for @video_upload, html: { multipart: true, class: "dash-form" } do |f| %>
        <%= render "shared/errors", object: @video_upload %>

        <div class="mb-3">
          <%= f.label :file, "Video file", class: "form-label" %>
          <%= f.file_field :file, class: "form-control", required: true, accept: "video/*" %>
        </div>

        <div class="mb-3">
          <%= f.label :title, class: "form-label" %>
          <%= f.text_field :title, class: "form-control", required: true, placeholder: "Video title" %>
        </div>

        <div class="mb-3">
          <%= f.label :description, class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Optional description" %>
        </div>

        <%= render "shared/dash_form_actions",
              form: f,
              cancel_path: all_videos_path,
              submit_label: "Upload Video" %>
      <% end %>
    <% else %>
      <div class="dash-empty padded">
        <p>Please sign in to upload videos.</p>
      </div>
    <% end %>
  <% end %>
</div>
