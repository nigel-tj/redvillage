<% content_for :title, "Edit Ticket Listing | The Red Cup Village" %>

<div class="dash">
  <%= render "dashboards/header",
        title: "Edit Listing",
        eyebrow: "Marketplace",
        subtitle: "Update your ticket listing details.",
        primary_path: ticket_listing_path(@ticket_listing),
        primary_label: "View Listing",
        primary_icon: "fas fa-eye",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Listing details", padded: true } do %>
    <%= form_with model: @ticket_listing, local: true, class: "dash-form" do |f| %>
      <%= render "shared/errors", object: @ticket_listing %>

      <div class="row g-3">
        <div class="col-12">
          <%= f.label :event_id, "Event", class: "form-label" %>
          <%= f.collection_select :event_id, @events, :id, :name, {}, { class: "form-select", disabled: true } %>
          <small class="form-text">Event cannot be changed after creation.</small>
        </div>

        <div class="col-12">
          <label class="form-label">Ticket type</label>
          <div class="dash-choice-grid">
            <div class="dash-choice">
              <%= f.radio_button :ticket_type, "standard", checked: @ticket_listing.ticket_type == "standard" %>
              <label for="ticket_listing_ticket_type_standard">
                <i class="fas fa-ticket-alt"></i>
                <strong>Standard</strong>
              </label>
            </div>
            <div class="dash-choice">
              <%= f.radio_button :ticket_type, "vip", checked: @ticket_listing.ticket_type == "vip" %>
              <label for="ticket_listing_ticket_type_vip">
                <i class="fas fa-star"></i>
                <strong>VIP</strong>
              </label>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <%= f.label :price, "Your price", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :price, step: 0.01, min: 0.01, class: "form-control", required: true %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :original_price, "Original price", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :original_price, step: 0.01, min: 0.01, class: "form-control" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :currency, "Currency", class: "form-label" %>
          <%= f.select :currency,
                [["USD ($)", "USD"], ["EUR (€)", "EUR"], ["GBP (£)", "GBP"]],
                {},
                { class: "form-select" } %>
        </div>
        <div class="col-md-6">
          <%= f.label :quantity, "Total tickets", class: "form-label" %>
          <%= f.number_field :quantity, min: [@ticket_listing.sold_quantity, 1].max, max: 100, class: "form-control", required: true %>
          <% if @ticket_listing.sold_quantity.to_i > 0 %>
            <small class="form-text">Cannot be less than <%= @ticket_listing.sold_quantity %> already sold.</small>
          <% end %>
        </div>
        <div class="col-md-6">
          <%= f.label :status, "Status", class: "form-label" %>
          <%= f.select :status,
                [["Available", "available"], ["Pending", "pending"], ["Sold", "sold"], ["Expired", "expired"]],
                {},
                { class: "form-select" } %>
        </div>
        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-control" %>
        </div>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: ticket_listing_path(@ticket_listing),
            submit_label: "Update Listing" %>
    <% end %>
  <% end %>
</div>
