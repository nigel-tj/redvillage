<% content_for :title, "#{@event.name} tickets — Red Village" %>

<div class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><%= link_to "Tickets", ticket_listings_path %></li>
      <li class="breadcrumb-item active" aria-current="page"><%= @event.name %></li>
    </ol>
  </nav>

  <div class="row g-4">
    <div class="col-lg-8">
      <% img = @event.image && (shrine_image_url(@event, :image, :large) || shrine_image_url(@event, :image)) %>
      <% if img.present? %>
        <div class="position-relative mb-4 rounded-4 overflow-hidden" style="max-height:380px;">
          <%= image_tag img, alt: @event.name, class: "w-100", style: "height:380px;object-fit:cover;" %>
          <span class="position-absolute top-0 end-0 m-3 badge" style="background:<%= @ticket_listing.ticket_type == 'vip' ? '#ffc857' : '#d34d94' %>;color:<%= @ticket_listing.ticket_type == 'vip' ? '#1a1033' : '#fff' %>;">
            <%= @ticket_listing.ticket_type.to_s.upcase %>
          </span>
        </div>
      <% end %>

      <div class="card rv-card mb-4">
        <div class="card-body">
          <h1 class="h2 mb-3"><%= @event.name %></h1>
          <% if @event.date %>
            <p class="mb-2"><i class="fas fa-calendar-alt me-2" style="color:#ff8fbf;"></i><%= @event.date.strftime("%A, %B %d, %Y") %></p>
          <% end %>
          <% if @event.venue.present? %>
            <p class="mb-2"><i class="fas fa-map-marker-alt me-2" style="color:#ff8fbf;"></i><%= @event.venue %></p>
          <% end %>
          <% if @event.start_time.present? %>
            <p class="mb-0"><i class="fas fa-clock me-2" style="color:#ff8fbf;"></i><%= @event.respond_to?(:formatted_start_time) ? @event.formatted_start_time : @event.start_time %></p>
          <% end %>

          <% if @ticket_listing.description.present? %>
            <hr class="border-secondary my-4">
            <h2 class="h5">About this listing</h2>
            <p class="text-muted mb-0" style="white-space:pre-wrap;"><%= @ticket_listing.description %></p>
          <% end %>

          <% if @event.summary.present? %>
            <hr class="border-secondary my-4">
            <h2 class="h5">Event details</h2>
            <p class="text-muted mb-0" style="white-space:pre-wrap;"><%= @event.summary %></p>
          <% end %>

          <% if @seller %>
            <hr class="border-secondary my-4">
            <h2 class="h5">Seller</h2>
            <div class="d-flex align-items-center gap-3">
              <div class="rv-t-avatar"><%= @seller.name.to_s.first.upcase %></div>
              <div>
                <div class="fw-bold"><%= @seller.name %></div>
                <div class="small text-muted">Member since <%= @seller.created_at.strftime("%B %Y") %></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card rv-card sticky-top" style="top:1rem;">
        <div class="card-body">
          <h2 class="h5 mb-3">Purchase</h2>
          <p class="mb-1">Available: <strong><%= @ticket_listing.available_quantity %>/<%= @ticket_listing.quantity %></strong></p>
          <p class="display-6 fw-bold mb-1" style="color:#ff8fbf;"><%= @ticket_listing.formatted_price %></p>
          <% if @ticket_listing.has_discount? %>
            <p class="text-muted text-decoration-line-through small"><%= @ticket_listing.formatted_original_price %></p>
          <% end %>
          <p class="small text-muted mb-4">per ticket</p>

          <% if @ticket_listing.is_available? %>
            <% if user_signed_in? %>
              <% if current_user == @ticket_listing.user %>
                <div class="alert alert-warning mb-0">This is your own listing.</div>
              <% else %>
                <p class="small text-muted">Contact the seller to complete your purchase.</p>
                <%= mail_to @seller&.email, "Contact seller", class: "btn btn-rv w-100", subject: "Ticket inquiry: #{@event.name}" if @seller&.email.present? %>
                <%= link_to "Back to marketplace", ticket_listings_path, class: "btn btn-outline-rv w-100 mt-2" %>
              <% end %>
            <% else %>
              <%= link_to "Sign up to purchase", new_user_registration_path, class: "btn btn-rv w-100 mb-2" %>
              <p class="small text-center text-muted mb-0">
                Already have an account? <%= link_to "Sign in", new_user_session_path, style: "color:#ff8fbf;" %>
              </p>
            <% end %>
          <% else %>
            <div class="alert alert-danger mb-0">Sold out.</div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
