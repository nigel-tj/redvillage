<% content_for :title, "My Ticket Listings | The Red Cup Village" %>

<div class="dash">
  <%= render "dashboards/header",
        title: "My Ticket Listings",
        eyebrow: "Marketplace",
        subtitle: "Manage your ticket sales.",
        primary_path: new_ticket_listing_path,
        primary_label: "Create Listing",
        primary_icon: "fas fa-plus",
        user: current_user %>

  <div class="dash-stats dash-stats--3">
    <%= render "dashboards/stat_card", label: "Available", value: @available_count, icon: "fas fa-ticket-alt" %>
    <%= render "dashboards/stat_card", label: "Sold", value: @sold_count, icon: "fas fa-check-circle" %>
    <%= render "dashboards/stat_card", label: "Revenue", value: "$#{sprintf('%.2f', @total_revenue)}", icon: "fas fa-dollar-sign" %>
  </div>

  <%= render layout: "dashboards/panel", locals: {
        title: "Your listings",
        action: link_to("Create Listing", new_ticket_listing_path, class: "btn-dash")
      } do %>
    <% if @ticket_listings.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Event</th>
              <th>Type</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @ticket_listings.each do |listing| %>
              <tr>
                <td>
                  <strong><%= listing.event.name %></strong>
                  <% if listing.event.date %>
                    <div class="small text-muted"><%= listing.event.date.strftime("%b %d, %Y") %></div>
                  <% end %>
                </td>
                <td>
                  <% if listing.ticket_type == "vip" %>
                    <span class="dash-badge">VIP</span>
                  <% else %>
                    <span class="dash-badge dash-badge--muted">Standard</span>
                  <% end %>
                </td>
                <td>
                  <strong><%= listing.formatted_price %></strong>
                  <% if listing.has_discount? %>
                    <div class="small text-muted text-decoration-line-through"><%= listing.formatted_original_price %></div>
                  <% end %>
                </td>
                <td>
                  <strong><%= listing.available_quantity %></strong>
                  <span class="text-muted">/ <%= listing.quantity %></span>
                </td>
                <td>
                  <% badge = case listing.status
                     when "available" then "dash-badge--ok"
                     when "pending" then "dash-badge--warn"
                     when "sold" then "dash-badge--danger"
                     else "dash-badge--muted"
                     end %>
                  <span class="dash-badge <%= badge %>"><%= listing.status.titleize %></span>
                </td>
                <td class="text-muted small"><%= time_ago_in_words(listing.created_at) %> ago</td>
                <td>
                  <%= link_to "View", ticket_listing_path(listing), class: "btn-dash btn-sm me-1" %>
                  <%= link_to "Edit", edit_ticket_listing_path(listing), class: "btn-dash-outline btn-sm me-1" %>
                  <%= link_to "Delete",
                        ticket_listing_path(listing),
                        method: :delete,
                        data: { confirm: "Delete this listing?" },
                        class: "btn-dash-danger btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dash-empty padded">
        <i class="fas fa-ticket-alt d-block"></i>
        <h3>No listings yet</h3>
        <p>Start selling by creating your first listing.</p>
        <%= link_to "Create Listing", new_ticket_listing_path, class: "btn-dash" %>
      </div>
    <% end %>
  <% end %>
</div>
