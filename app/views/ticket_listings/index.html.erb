<% content_for :title, "Ticket Marketplace — Red Village" %>

<div class="container py-4">
  <div class="rv-section-head">
    <h1 class="rv-gradient-text">Ticket marketplace</h1>
    <p class="rv-sub">Buy and sell event tickets from the Red Village community.</p>
    <hr class="rv-rule">
  </div>

  <div class="card rv-card mb-4">
    <div class="card-body">
      <%= form_with url: ticket_listings_path, method: :get, local: true, class: "row g-3 align-items-end" do |f| %>
        <div class="col-md-4">
          <%= f.label :search, "Search", class: "form-label small text-muted" %>
          <%= f.text_field :search, value: params[:search], placeholder: "Search events…", class: "form-control" %>
        </div>
        <div class="col-md-3">
          <%= f.label :event_id, "Event", class: "form-label small text-muted" %>
          <%= f.select :event_id,
                options_from_collection_for_select(@events || Event.order(:date), :id, :name, params[:event_id]),
                { prompt: "All events" },
                { class: "form-control" } %>
        </div>
        <div class="col-md-2">
          <%= f.label :ticket_type, "Type", class: "form-label small text-muted" %>
          <%= f.select :ticket_type,
                [["All types", ""], ["Standard", "standard"], ["VIP", "vip"]],
                { selected: params[:ticket_type] },
                { class: "form-control" } %>
        </div>
        <div class="col-md-2">
          <%= f.label :sort, "Sort", class: "form-label small text-muted" %>
          <%= f.select :sort,
                [["Newest", "newest"], ["Price: Low to High", "price_asc"], ["Price: High to Low", "price_desc"]],
                { selected: params[:sort] || "newest" },
                { class: "form-control" } %>
        </div>
        <div class="col-md-1">
          <%= f.submit "Go", class: "btn btn-rv w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if user_signed_in? %>
    <div class="d-flex flex-wrap gap-2 justify-content-center mb-4">
      <%= link_to "Sell tickets", new_ticket_listing_path, class: "btn btn-rv" %>
      <%= link_to "My listings", my_tickets_path, class: "btn btn-outline-rv" %>
    </div>
  <% end %>

  <% if @event %>
    <div class="alert mb-4" style="background:rgba(211,77,148,0.12);border:1px solid rgba(211,77,148,0.35);color:#fbf9ff;">
      Showing tickets for <strong><%= @event.name %></strong>
      <% if @event.date %>— <%= @event.date.strftime("%B %d, %Y") %><% end %>
      <%= link_to "Clear", ticket_listings_path, class: "float-end", style: "color:#ff8fbf;" %>
    </div>
  <% end %>

  <% if @ticket_listings.any? %>
    <div class="row g-4">
      <% @ticket_listings.each do |listing| %>
        <div class="col-md-6 col-lg-4">
          <div class="card rv-card h-100">
            <% img = listing.event && (shrine_image_url(listing.event, :image, :medium) || shrine_image_url(listing.event, :image)) %>
            <% if img.present? %>
              <%= image_tag img, alt: listing.event.name, class: "rv-img" %>
            <% else %>
              <div class="rv-thumb-placeholder"><i class="fas fa-ticket-alt fa-2x"></i></div>
            <% end %>
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                <h2 class="h5 card-title mb-0">
                  <%= link_to listing.event&.name || "Event", ticket_listing_path(listing), class: "text-decoration-none" %>
                </h2>
                <span class="badge" style="background:<%= listing.ticket_type == 'vip' ? 'rgba(255,201,87,0.2)' : 'rgba(255,105,117,0.2)' %>;color:<%= listing.ticket_type == 'vip' ? '#ffc857' : '#ff8fbf' %>;">
                  <%= listing.ticket_type.to_s.upcase %>
                </span>
              </div>
              <p class="small text-muted mb-2">Sold by <%= listing.user&.name %></p>
              <% if listing.description.present? %>
                <p class="small text-muted"><%= truncate(listing.description, length: 90) %></p>
              <% end %>
              <p class="mb-1 fw-bold" style="color:#ff8fbf;"><%= listing.formatted_price %></p>
              <p class="small text-muted mb-0"><%= listing.available_quantity %>/<%= listing.quantity %> available</p>
            </div>
            <div class="card-footer border-0 bg-transparent">
              <% if listing.is_available? %>
                <%= link_to "View details", ticket_listing_path(listing), class: "btn btn-rv btn-rv-sm w-100" %>
              <% else %>
                <button class="btn btn-secondary btn-sm w-100" disabled>Sold out</button>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted py-5 mb-0">No ticket listings match your filters.</p>
  <% end %>
</div>
