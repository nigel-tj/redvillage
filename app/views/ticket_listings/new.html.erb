<% content_for :title, "List Your Tickets | The Red Cup Village" %>

<div class="dash">
  <%= render "dashboards/header",
        title: "List Your Tickets",
        eyebrow: "Marketplace",
        subtitle: "Create a listing and start selling extra tickets.",
        primary_path: my_tickets_path,
        primary_label: "My Listings",
        primary_icon: "fas fa-ticket-alt",
        user: current_user %>

  <%= render layout: "dashboards/panel", locals: { title: "Listing details", padded: true } do %>
    <%= form_with model: @ticket_listing, local: true, class: "dash-form" do |f| %>
      <%= render "shared/errors", object: @ticket_listing %>

      <div class="row g-3">
        <div class="col-12">
          <%= f.label :event_id, "Event", class: "form-label" %>
          <%= f.collection_select :event_id, @events, :id, :name,
                { prompt: "Choose an event…" },
                { class: "form-select", required: true } %>
        </div>

        <div class="col-12">
          <label class="form-label">Ticket type</label>
          <div class="dash-choice-grid">
            <div class="dash-choice">
              <%= f.radio_button :ticket_type, "standard",
                    checked: @ticket_listing.ticket_type == "standard" || @ticket_listing.ticket_type.blank?,
                    required: true %>
              <label for="ticket_listing_ticket_type_standard">
                <i class="fas fa-ticket-alt"></i>
                <strong>Standard</strong>
                <small>Regular admission</small>
              </label>
            </div>
            <div class="dash-choice">
              <%= f.radio_button :ticket_type, "vip",
                    checked: @ticket_listing.ticket_type == "vip",
                    required: true %>
              <label for="ticket_listing_ticket_type_vip">
                <i class="fas fa-star"></i>
                <strong>VIP</strong>
                <small>Premium access</small>
              </label>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <%= f.label :price, "Your price", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :price, step: 0.01, min: 0.01, class: "form-control", placeholder: "0.00", required: true, id: "ticket-price" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :original_price, "Original price", class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <%= f.number_field :original_price, step: 0.01, min: 0.01, class: "form-control", placeholder: "Optional", id: "ticket-original-price" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.label :currency, "Currency", class: "form-label" %>
          <%= f.select :currency,
                [["USD ($)", "USD"], ["EUR (€)", "EUR"], ["GBP (£)", "GBP"]],
                {},
                { class: "form-select" } %>
        </div>
        <div class="col-md-6">
          <%= f.label :quantity, "Total tickets", class: "form-label" %>
          <%= f.number_field :quantity, min: 1, max: 100, class: "form-control", placeholder: "1", required: true %>
        </div>
        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-control",
                placeholder: "Seat location, condition, why you're selling…" %>
        </div>
      </div>

      <%= render "shared/dash_form_actions",
            form: f,
            cancel_path: ticket_listings_path,
            submit_label: "Create Listing" %>
    <% end %>
  <% end %>
</div>
