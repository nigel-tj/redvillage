# Production environment template — copy to .env.production and replace placeholders.
# Never commit .env.production.

# Database Configuration
DATABASE_USERNAME=redvillage
DATABASE_PASSWORD=replace_with_strong_password
DATABASE_HOST=db
DATABASE_PORT=3306

# MySQL (docker-compose.prod.yml)
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_DATABASE=redvillage_production
MYSQL_USER=redvillage
MYSQL_PASSWORD=replace_with_strong_password

# Rails Configuration
RAILS_ENV=production
RACK_ENV=production
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
RAILS_SERVE_STATIC_FILES=false
RAILS_LOG_TO_STDOUT=true
RAILS_LOG_LEVEL=info

# Application Secrets — generate with: rails secret
SECRET_KEY_BASE=replace_with_rails_secret

# Server
PORT=3000

# Optional: Stripe
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=

# Optional: Email
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_DOMAIN=your_domain.com
# MAIL_FROM=noreply@your_domain.com
