# Development Dockerfile - optimized for development workflow
FROM ruby:3.2.2-slim

# Install essential packages (including dev dependencies)
RUN apt-get update -qq && apt-get install -y \
    build-essential \
    nodejs \
    default-mysql-client \
    default-libmysqlclient-dev \
    imagemagick \
    libmagickwand-dev \
    ffmpeg \
    git \
    curl \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install gems (including development and test groups)
COPY Gemfile Gemfile.lock ./
RUN bundle config --global frozen 0 && \
    bundle install --jobs 4 --retry 3

# Copy entrypoint script
COPY entrypoint.sh /usr/bin/entrypoint.sh
RUN chmod +x /usr/bin/entrypoint.sh

# Copy application code (will be overridden by volume mount in docker-compose)
COPY . .

# Expose port
EXPOSE 3000

# Set environment
ENV RAILS_ENV=development
ENV RAILS_LOG_TO_STDOUT=true

# Use entrypoint but allow CMD override
ENTRYPOINT ["/usr/bin/entrypoint.sh"]
CMD ["bundle", "exec", "rails", "server", "-b", "0.0.0.0", "-p", "3000"]


